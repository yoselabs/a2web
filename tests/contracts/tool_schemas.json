        },
        "ExtractionMeta": {
          "description": "Per-fetch LLM extraction metadata.\n\nPopulated by the v0.4 `ask=` pipeline on `FetchResponse.extraction`.\nMirrors what `a2web.llm.ExtractionResult` carries, minus the answer\ntext (which lives on `FetchResponse.extracted_answer` for ergonomic\ndirect access).",
          "properties": {
            "cache_hit": {
              "default": false,
              "title": "Cache Hit",
              "type": "boolean"
            },
            "completion_tokens": {
              "default": 0,
              "title": "Completion Tokens",
              "type": "integer"
            },
            "cost_usd": {
              "default": 0.0,
              "title": "Cost Usd",
              "type": "number"
            },
            "latency_ms": "<volatile>",
            "model": {
              "title": "Model",
              "type": "string"
            },
            "prompt_tokens": {
              "default": 0,
              "title": "Prompt Tokens",
              "type": "integer"
            },
            "template_name": {
              "title": "Template Name",
              "type": "string"
            },
            "truncated": {
              "default": false,
              "title": "Truncated",
              "type": "boolean"
            }
          },
          "required": [
            "model",
            "template_name"
          ],
          "title": "ExtractionMeta",
          "type": "object"
        },
        "FetchStatus": {
          "enum": [
            "ok",
            "failed",
            "partial"
          ],
          "title": "FetchStatus",
          "type": "string"
        },
        "Heading": {
