                  {
                    "type": "integer"
                  },
                  {
                    "type": "number"
                  }
                ]
              },
              "title": "Extra",
              "type": "object"
            },
            "host": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Host"
            },
            "proxy": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Proxy"
            },
            "step": {
              "title": "Step",
              "type": "string"
            },
            "subsystem": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Subsystem"
            },
            "t_ms": "<volatile>",
            "verdict": {
              "$ref": "#/$defs/Verdict"
            }
          },
          "required": [
