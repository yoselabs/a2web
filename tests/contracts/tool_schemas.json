        "include_content": {
          "default": false,
          "title": "Include Content",
          "type": "boolean"
        },
        "include_links": {
          "default": false,
          "title": "Include Links",
          "type": "boolean"
        },
        "link_roles": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
