              "title": "Reason",
              "type": "string"
            },
            "url": {
              "title": "Url",
              "type": "string"
            }
          },
          "required": [
            "url",
            "reason"
          ],
          "title": "NextUrl",
          "type": "object"
        },
        "OperatorHint": {
          "description": "Structured hint about how the fetch could be improved.\n\n`code` is a stable agent-readable identifier (e.g. `llm_unavailable`,\n`browser_unavailable`, `browser_internal_error`, `captcha_redirect`,\n`cookies_stale`). Agents may\nbranch on `code` to take a next action; humans read `message` and `fix`\nfor context and remediation. Both audiences are first-class \u2014 the field\nlanded under the \"operator\" name historically, not because agents\nshouldn't read it.",
          "properties": {
            "code": {
              "title": "Code",
              "type": "string"
            },
            "fix": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Fix"
            },
            "message": {
              "title": "Message",
              "type": "string"
            },
            "severity": {
              "default": "info",
              "enum": [
                "info",
                "critical"
              ],
              "title": "Severity",
              "type": "string"
            }
          },
          "required": [
            "code",
            "message"
          ],
          "title": "OperatorHint",
          "type": "object"
        },
        "RouterPayload": {
          "description": "Router-shape payload emitted by the `extract_router_v1` template.\n\nThree required fields (`answer`, `structural_form`, `shape`) describe what\nthe page IS. Four conditional fields (`genre`, `obstacle`, `ask_here`,\n`try_url`) describe what it's ABOUT plus drilldown hints; the serializer\non `AskResponse` omits the conditionals from the wire when empty.",
          "properties": {
            "answer": {
              "title": "Answer",
              "type": "string"
            },
            "ask_here": {
              "items": {
                "type": "string"
              },
              "title": "Ask Here",
              "type": "array"
            },
            "genre": {
              "anyOf": [
                {
                  "enum": [
                    "news",
                    "encyclopedia",
                    "spec",
                    "paper",
                    "personal",
                    "official",
                    "community"
                  ],
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Genre"
            },
            "obstacle": {
              "anyOf": [
                {
                  "enum": [
                    "paywalled",
                    "blocked",
                    "empty",
                    "error"
                  ],
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Obstacle"
            },
            "shape": {
              "enum": [
                "prose",
                "records",
                "key-value",
                "code",
                "table",
                "discussion",
                "mixed"
              ],
              "title": "Shape",
              "type": "string"
            },
            "structural_form": {
              "enum": [
                "article",
                "thread",
                "listing",
                "reference",
                "tutorial",
                "changelog",
                "code",
                "product",
                "media",
                "other"
              ],
              "title": "Structural Form",
              "type": "string"
            },
            "try_url": {
              "items": {
                "$ref": "#/$defs/NextUrl"
              },
              "title": "Try Url",
              "type": "array"
            }
          },
          "required": [
            "answer",
            "structural_form",
            "shape"
          ],
          "title": "RouterPayload",
          "type": "object"
        },
        "TokenCounts": {
          "properties": {
            "full": {
              "title": "Full",
              "type": "integer"
            }
          },
          "required": [
            "full"
          ],
          "title": "TokenCounts",
          "type": "object"
        },
        "Verdict": {
          "enum": [
            "ok",
            "paywall",
            "block_page_detected",
            "anti_bot",
            "length_floor",
            "content_type_mismatch",
            "connection_error",
            "timeout",
            "not_found",
            "rate_limited",
            "proxy_unavailable",
            "paid_auth_error",
            "other"
          ],
          "title": "Verdict",
          "type": "string"
        }
      },
      "description": "The response envelope returned by the `fetch_raw` tool.\n\nField tiers govern what reaches the wire (the serializer regroups /\ndrops; the builder populates the model in full for internal callers):\n\n- Always present: `confidence`.\n- Deviation-only: `status` (dropped when `ok`), `tier` (dropped when\n  `raw`), `url` (dropped when it equals the requested URL \u2014 absence means\n  the fetch landed exactly where the caller asked).\n- Failure-only: `narrative`, `diagnostics_summary` \u2014 dropped on success.\n- Debug-only: `started_at`, `total_ms`, `cache`, `tokens`, `diagnostics`\n  regroup into a nested `debug` object, present only under `debug=True`.\n- Omitted when empty: `title`, `byline`, `published`, `meta`, `links`,\n  `headings`, `operator_hints`, `next_links`, `extraction`,\n  `extracted_answer` (and `content_md` on a failed fetch).\n- TSV-rendered: `links` and `next_links` ship as tab-separated blocks.",
      "properties": {
        "byline": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Byline"
        },
        "cache": "<volatile>",
        "confidence": {
          "$ref": "#/$defs/Confidence"
        },
        "content_candidates": {
          "items": {
            "$ref": "#/$defs/ContentCandidateWire"
          },
          "title": "Content Candidates",
          "type": "array"
        },
        "content_md": {
          "default": "",
          "title": "Content Md",
          "type": "string"
        },
        "diagnostics": {
          "items": {
            "$ref": "#/$defs/Diagnostic"
          },
          "title": "Diagnostics",
          "type": "array"
        },
        "diagnostics_summary": {
          "default": "",
          "title": "Diagnostics Summary",
          "type": "string"
        },
        "extracted_answer": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Extracted Answer"
        },
        "extraction": {
          "anyOf": [
            {
              "$ref": "#/$defs/ExtractionMeta"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "headings": {
          "items": {
            "$ref": "#/$defs/Heading"
          },
          "title": "Headings",
          "type": "array"
        },
        "links": {
          "items": {
            "$ref": "#/$defs/Link"
          },
          "title": "Links",
          "type": "array"
        },
        "meta": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Meta",
          "type": "object"
        },
        "narrative": {
          "default": "",
          "title": "Narrative",
          "type": "string"
        },
        "next_links": {
          "items": {
            "$ref": "#/$defs/NextLink"
          },
          "title": "Next Links",
          "type": "array"
        },
        "operator_hints": {
          "items": {
            "$ref": "#/$defs/OperatorHint"
          },
          "title": "Operator Hints",
          "type": "array"
        },
        "published": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Published"
        },
        "retrieval_incomplete": {
          "default": false,
          "title": "Retrieval Incomplete",
          "type": "boolean"
        },
        "routing": {
          "anyOf": [
            {
              "$ref": "#/$defs/RouterPayload"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "started_at": "<volatile>",
        "status": {
          "$ref": "#/$defs/FetchStatus"
        },
        "tier": {
          "title": "Tier",
          "type": "string"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Title"
        },
        "tokens": {
          "anyOf": [
            {
              "$ref": "#/$defs/TokenCounts"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "total_ms": "<volatile>",
        "url": {
          "title": "Url",
          "type": "string"
        }
      },
      "required": [
        "url",
        "status",
        "tier",
        "confidence"
      ],
      "title": "FetchResponse",
      "type": "object"
    }
  }
}
