redients-nutrition" data-component="TabbedList"><div class="tabbed-list__header"><h2 class="tabbed-list__tab heading-3"><button type="button" class="tabbed-list__tab-button tabbed-list__tab-button--active" data-feature="TabbedListButton" data-feature-variant="Left" data-index="1">Ingredients</button></h2><h2 class="tabbed-list__tab heading-3"><button type="button" class="tabbed-list__tab-button" data-feature="TabbedListButton" data-feature-variant="Right" data-index="2">Nutrition</button></h2></div><div class="tabbed-list__content"><div class=""><section id="ingredients-list" class="ingredients-list" data-component="IngredientsList" data-feature="Recipe Instructions" data-testid="ingredients-list" data-stitcher-dai-container="ingredients-list"><section data-testid="section-undefined"><ul class="ingredients-list list"><li class="ingredients-list__item list-item"><span class="ingredients-list__item-quantity">140g </span><a class="link link--styled" href="/glossary/butter-glossary" data-component="Link"><span class="ingredients-list__item-ingredient">butter</span></a><div class="ingredients-list__item-note"> softened, plus extra for the tin</div></li><li class="ingredients-list__item list-item list-item--separator-top"><span class="ingredients-list__item-quantity">140g </span><a class="link link--styled" href="/glossary/sugar-glossary" data-component="Link"><span class="ingredients-list__item-ingredient">caster sugar</span></a></li><li class="ingredients-list__item list-item list-item--separator-top"><span class="ingredients-list__item-quantity">2 large </span><a class="link link--styled" href="/glossary/egg-glossary" data-component="Link"><span class="ingredients-list__item-ingredient">eggs</span></a><div class="ingredients-list__item-note"> beaten</div></li><li class="ingredients-list__item list-item list-item--separator-top"><span class="ingredients-list__item-quantity">140g </span><a class="link link--styled" href="/glossary/flour-glossary" data-component="Link"><span class="ingredients-list__item-ingredient">self-raising flour</span></a></li><li class="ingredients-list__item list-item list-item--separator-top"><span class="ingredients-list__item-quantity">1 tsp </span><a class="link link--styled" href="/glossary/baking-powder-glossary" data-component="Link"><span class="ingredients-list__item-ingredient">baking powder</span></a></li><li class="ingredients-list__item list-item list-item--separator-top"><span class="ingredients-list__item-quantity">2 very ripe  </span><a class="link link--styled" href="/glossary/banana-glossary" data-component="Link"><span class="ingredients-list__item-ingredient">bananas</span></a><div class="ingredients-list__item-note"> mashed</div></li><li class="ingredients-list__item list-item list-item--separator-top"><span class="ingredients-list__item-quantity">50g </span><a class="link link--styled" href="/glossary/sugar-glossary" data-component="Link"><span class="ingredients-list__item-ingredient">icing sugar</span></a></li><li class="ingredients-list__item list-item list-item--separator-top"><span class="ingredients-list__item-quantity">handful </span><a class="link link--styled" href="/glossary/banana-glossary" data-component="Link"><span class="ingredients-list__item-ingredient">dried banana chips</span></a><div class="ingredients-list__item-note"> for decoration</div></li></ul></section><div class="pocket hidden-print pocket--horizontal ingredients-list__heading list-item--separator-top mt-xs pt-xs" data-placement="recipeBelowIngredients"><div class="d-flex"><div data-feature="promotionalWidget" data-feature-variant="promoLink"><div class="line-clamper" data-testid="root"><div class="region-clamper line-clamper__content" style="line-clamp:3;-webkit-line-clamp:3" data-testid="region-clamper">Keep the screen awake with cook mode on the<!-- --> <a class="link link--styled" href="https://immediate.onelink.me/OQap?af_xp=custom&amp;pid=website&amp;c=ingredients_CTA&amp;is_retargeting=true&amp;af_reengagement_window=30d&amp;af_dp=bbcgoodfood%3A%2F%2F" data-component="Link">Good Food app.</a></div></div></div></div></div></section></div><div class="d-none"><p class="recipe__nutritions-caption" data-testid="nutritions-caption">Nutrition: per slice (10)</p><ul class="nutrition-list" data-testid="nutritions-list"><li class="nutrition-list__item"><span class="nutrition-list__label">kcal</span>268</li><li class="nutrition-list__item"><span class="nutrition-list__label">fat</span>13<!-- -->g</li><li class="nutrition-list__item"><span class="nutrition-list__label">saturates</span>8<!-- -->g</li><li class="nutrition-list__item"><span class="nutrition-list__label">carbs</span>34<!-- -->g</li><li class="nutrition-list__item"><span class="nutrition-list__label">sugars</span>24<!-- -->g</li><li class="nutrition-list__item"><span class="nutrition-list__label">fibre</span>1<!-- -->g</li><li class="nutrition-list__item"><span class="nutrition-list__label">protein</span>3<!-- -->g</li><li class="nutrition-list__item"><span class="nutrition-list__label">salt</span>0.5<!-- -->g</li></ul></div></div></div><div class="ad-slot__below-ingredients align-items-center ad-slot hidden-print ad-slot__below-ingredients ad-slot--bordered" data-testid="ad-slot"><div class="ad-slot__container ad-slot__below-ingredients-container below-ingredients--1" data-testid="ad-slot__container"><div class="ad-slot__label chromatic-ignore"><span class="ad-slot__text">Ad</span></div><div id="recipe--below-ingredients--1" data-testid="ad-unit" class="ad-unit"></div></div><div><script>(window.adq = window.adq || []).push((api) => api.addSlot({"key":"below-ingredients","index":1,"searchTerm":null,"fullSearchTerm":null}));</script></div></div><section class="method-steps mb-lg" data-placement="MethodList"><h2 class="method-steps__heading heading-3">Method</h2><ul class="method-steps__list"><li class="method-steps__list-item"><h3 class="method-steps__item-heading heading-5">step 1</h3><div class="editor-content"><p>Heat oven to 180C/160C fan/gas 4. Butter a 2lb <a href="https://www.bbcgoodfood.com/howto/guide/baking-equipment">loaf tin</a> and line the base and sides with baking parchment.</p><div class="image chromatic-ignore" data-testid="image"><div class="image__container" style="max-width:700px" data-testid="image-container"><picture class="image__picture" data-testid="image-picture" width="700" height="466.2903225806452"><source data-testid="image-source" type="image/webp" sizes="(min-width: 992px) 940px,(min-width: 768px) 728px,(min-width: 544px) 556px,calc(100vw - 20px)" srcSet="https://images.immediate.co.uk/production/volatile/sites/30/2013/04/1.-Lining-tin-0b46cdd.jpg?quality=90&amp;webp=true&amp;fit=325,216 325w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/1.-Lining-tin-0b46cdd.jpg?quality=90&amp;webp=true&amp;fit=375,250 375w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/1.-Lining-tin-0b46cdd.jpg?quality=90&amp;webp=true&amp;fit=650,433 650w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/1.-Lining-tin-0b46cdd.jpg?quality=90&amp;webp=true&amp;fit=750,500 750w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/1.-Lining-tin-0b46cdd.jpg?quality=90&amp;webp=true&amp;fit=975,649 975w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/1.-Lining-tin-0b46cdd.jpg?quality=90&amp;webp=true&amp;fit=1000,666 1000w"/><source data-testid="image-source" sizes="(min-width: 992px) 940px,(min-width: 768px) 728px,(min-width: 544px) 556px,calc(100vw - 20px)" srcSet="https://images.immediate.co.uk/production/volatile/sites/30/2013/04/1.-Lining-tin-0b46cdd.jpg?quality=90&amp;fit=325,216 325w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/1.-Lining-tin-0b46cdd.jpg?quality=90&amp;fit=375,250 375w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/1.-Lining-tin-0b46cdd.jpg?quality=90&amp;fit=650,433 650w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/1.-Lining-tin-0b46cdd.jpg?quality=90&amp;fit=750,500 750w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/1.-Lining-tin-0b46cdd.jpg?quality=90&amp;fit=975,649 975w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/1.-Lining-tin-0b46cdd.jpg?quality=90&amp;fit=1000,666 1000w"/><img class="image__img" src="https://images.immediate.co.uk/production/volatile/sites/30/2013/04/1.-Lining-tin-0b46cdd.jpg?quality=90&amp;fit=700,466" alt="Loaf tin lined with baking parchment" data-item-name="Loaf tin lined with baking parchment" title="Banana bread recipe" style="aspect-ratio:1 / 0.6661290322580645;object-fit:contain" loading="lazy" width="700" height="466.2903225806452" data-testid="image-img"/></picture></div></div></div></li><li class="method-steps__list-item"><h3 class="method-steps__item-heading heading-5">step 2</h3><div class="editor-content"><p><a href="https://www.bbcgoodfood.com/content/test-five-best-food-processors">Cream</a> 140g softened butter and 140g caster sugar until light and fluffy, then slowly add 2 beaten large eggs with a little of the 140g flour.</p><div class="image chromatic-ignore" data-testid="image"><div class="image__container" style="max-width:700px" data-testid="image-container"><picture class="image__picture" data-testid="image-picture" width="700" height="466.2903225806452"><source data-testid="image-source" type="image/webp" sizes="(min-width: 992px) 940px,(min-width: 768px) 728px,(min-width: 544px) 556px,calc(100vw - 20px)" srcSet="https://images.immediate.co.uk/production/volatile/sites/30/2013/04/2.-Creamed-sugar-and-egg-v2-61a46fb.jpg?quality=90&amp;webp=true&amp;fit=325,216 325w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/2.-Creamed-sugar-and-egg-v2-61a46fb.jpg?quality=90&amp;webp=true&amp;fit=375,250 375w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/2.-Creamed-sugar-and-egg-v2-61a46fb.jpg?quality=90&amp;webp=true&amp;fit=650,433 650w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/2.-Creamed-sugar-and-egg-v2-61a46fb.jpg?quality=90&amp;webp=true&amp;fit=750,500 750w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/2.-Creamed-sugar-and-egg-v2-61a46fb.jpg?quality=90&amp;webp=true&amp;fit=975,649 975w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/2.-Creamed-sugar-and-egg-v2-61a46fb.jpg?quality=90&amp;webp=true&amp;fit=1000,666 1000w"/><source data-testid="image-source" sizes="(min-width: 992px) 940px,(min-width: 768px) 728px,(min-width: 544px) 556px,calc(100vw - 20px)" srcSet="https://images.immediate.co.uk/production/volatile/sites/30/2013/04/2.-Creamed-sugar-and-egg-v2-61a46fb.jpg?quality=90&amp;fit=325,216 325w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/2.-Creamed-sugar-and-egg-v2-61a46fb.jpg?quality=90&amp;fit=375,250 375w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/2.-Creamed-sugar-and-egg-v2-61a46fb.jpg?quality=90&amp;fit=650,433 650w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/2.-Creamed-sugar-and-egg-v2-61a46fb.jpg?quality=90&amp;fit=750,500 750w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/2.-Creamed-sugar-and-egg-v2-61a46fb.jpg?quality=90&amp;fit=975,649 975w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/2.-Creamed-sugar-and-egg-v2-61a46fb.jpg?quality=90&amp;fit=1000,666 1000w"/><img class="image__img" src="https://images.immediate.co.uk/production/volatile/sites/30/2013/04/2.-Creamed-sugar-and-egg-v2-61a46fb.jpg?quality=90&amp;fit=700,466" alt="Creaming butter and egg in a glass bowl" data-item-name="Creaming butter and egg in a glass bowl" title="Banana bread recipe" style="aspect-ratio:1 / 0.6661290322580645;object-fit:contain" loading="lazy" width="700" height="466.2903225806452" data-testid="image-img"/></picture></div></div></div></li><li class="method-steps__list-item"><h3 class="method-steps__item-heading heading-5">step 3</h3><div class="editor-content"><p>Fold in the remaining flour, 1 tsp baking powder and 2 mashed bananas.</p><div class="image chromatic-ignore" data-testid="image"><div class="image__container" style="max-width:700px" data-testid="image-container"><picture class="image__picture" data-testid="image-picture" width="700" height="466.2903225806452"><source data-testid="image-source" type="image/webp" sizes="(min-width: 992px) 940px,(min-width: 768px) 728px,(min-width: 544px) 556px,calc(100vw - 20px)" srcSet="https://images.immediate.co.uk/production/volatile/sites/30/2013/04/4.-Add-flour-banana-v2-4e08754.jpg?quality=90&amp;webp=true&amp;fit=325,216 325w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/4.-Add-flour-banana-v2-4e08754.jpg?quality=90&amp;webp=true&amp;fit=375,250 375w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/4.-Add-flour-banana-v2-4e08754.jpg?quality=90&amp;webp=true&amp;fit=650,433 650w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/4.-Add-flour-banana-v2-4e08754.jpg?quality=90&amp;webp=true&amp;fit=750,500 750w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/4.-Add-flour-banana-v2-4e08754.jpg?quality=90&amp;webp=true&amp;fit=975,649 975w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/4.-Add-flour-banana-v2-4e08754.jpg?quality=90&amp;webp=true&amp;fit=1000,666 1000w"/><source data-testid="image-source" sizes="(min-width: 992px) 940px,(min-width: 768px) 728px,(min-width: 544px) 556px,calc(100vw - 20px)" srcSet="https://images.immediate.co.uk/production/volatile/sites/30/2013/04/4.-Add-flour-banana-v2-4e08754.jpg?quality=90&amp;fit=325,216 325w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/4.-Add-flour-banana-v2-4e08754.jpg?quality=90&amp;fit=375,250 375w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/4.-Add-flour-banana-v2-4e08754.jpg?quality=90&amp;fit=650,433 650w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/4.-Add-flour-banana-v2-4e08754.jpg?quality=90&amp;fit=750,500 750w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/4.-Add-flour-banana-v2-4e08754.jpg?quality=90&amp;fit=975,649 975w,https://images.immediate.co.uk/production/volatile/sites/30/2013/04/4.-Add-flour-banana-v2-4e08754.jpg?quality=90&amp;fit=1000,666 1000w"/><img class="image__img" src="https://images.immediate.co.uk/production/volatile/sites/30/2013/04/4.-Add-flour-banana-v2-4e08754.jpg?quality=90&amp;fit=700,466" alt="Mashed banana and flour mixed in a glass bowl" data-item-name="Mashed banana and flour mixed in a glass bowl" title="Banana bread recipe" style="aspect-ratio:1 / 0.6661290322580645;object-fit:contain" loading="lazy" width="700" height="466.2903225806452" data-testid="image-img"/></picture></div></div></div></li><li class="method-steps__list-item"><h3 class="method-steps__item-heading heading-5">step 4</h3><div class="editor-content"><p>Pour the mixture into the prepared tin and bake for about 50 mins, or until cooked through. Check the loaf at 5-min intervals from around 30-40 mins in the oven by testing it with a skewer (it should be able to be inserted and removed cleanly), as the time may vary depending on the shape of your loaf tin.</p><div class="image chromatic-ignore" data-testid="image"><div class="image__container" style="max-width:700px" data-testid="image-container"><picture class="image__picture" data-testid="image-picture" width="700" height="466.2903225806452"><source data-testid="image-source" type="image/webp" sizes="(min-width: 992px) 940px,(min-width: 768px) 728px,(min-width: 544px) 556px,calc(100vw - 20px)" srcSet="https://images.immediate.co.uk/production/volatile/sites/30/2025/02/5.-Mixture-in-tin-v2-64c2ad3.jpg?quality=90&amp;webp=true&amp;fit=325,216 325w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/5.-Mixture-in-tin-v2-64c2ad3.jpg?quality=90&amp;webp=true&amp;fit=375,250 375w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/5.-Mixture-in-tin-v2-64c2ad3.jpg?quality=90&amp;webp=true&amp;fit=650,433 650w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/5.-Mixture-in-tin-v2-64c2ad3.jpg?quality=90&amp;webp=true&amp;fit=750,500 750w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/5.-Mixture-in-tin-v2-64c2ad3.jpg?quality=90&amp;webp=true&amp;fit=975,649 975w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/5.-Mixture-in-tin-v2-64c2ad3.jpg?quality=90&amp;webp=true&amp;fit=1000,666 1000w"/><source data-testid="image-source" sizes="(min-width: 992px) 940px,(min-width: 768px) 728px,(min-width: 544px) 556px,calc(100vw - 20px)" srcSet="https://images.immediate.co.uk/production/volatile/sites/30/2025/02/5.-Mixture-in-tin-v2-64c2ad3.jpg?quality=90&amp;fit=325,216 325w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/5.-Mixture-in-tin-v2-64c2ad3.jpg?quality=90&amp;fit=375,250 375w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/5.-Mixture-in-tin-v2-64c2ad3.jpg?quality=90&amp;fit=650,433 650w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/5.-Mixture-in-tin-v2-64c2ad3.jpg?quality=90&amp;fit=750,500 750w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/5.-Mixture-in-tin-v2-64c2ad3.jpg?quality=90&amp;fit=975,649 975w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/5.-Mixture-in-tin-v2-64c2ad3.jpg?quality=90&amp;fit=1000,666 1000w"/><img class="image__img" src="https://images.immediate.co.uk/production/volatile/sites/30/2025/02/5.-Mixture-in-tin-v2-64c2ad3.jpg?quality=90&amp;fit=700,466" alt="Cake mixture in lined tin" data-item-name="Cake mixture in lined tin" title="5.-Mixture-in-tin-v2" style="aspect-ratio:1 / 0.6661290322580645;object-fit:contain" loading="lazy" width="700" height="466.2903225806452" data-testid="image-img"/></picture></div></div></div></li><li class="method-steps__list-item"><h3 class="method-steps__item-heading heading-5">step 5</h3><div class="editor-content"><p>Cool in the tin for 10 mins, then remove to a <a href="https://www.bbcgoodfood.com/content/kimberley-wilsons-top-five-cooling-racks">wire rack</a>.</p><div class="ad-placement" data-count="709"></div></div></li><li class="method-steps__list-item"><h3 class="method-steps__item-heading heading-5">step 6</h3><div class="editor-content"><p>Mix 50g icing sugar with 2-3 tsp water to make a runny icing.</p><div class="image chromatic-ignore" data-testid="image"><div class="image__container" style="max-width:700px" data-testid="image-container"><picture class="image__picture" data-testid="image-picture" width="700" height="466.2903225806452"><source data-testid="image-source" type="image/webp" sizes="(min-width: 992px) 940px,(min-width: 768px) 728px,(min-width: 544px) 556px,calc(100vw - 20px)" srcSet="https://images.immediate.co.uk/production/volatile/sites/30/2025/02/6.-Icing-sugar-v2-edea1e6.jpg?quality=90&amp;webp=true&amp;fit=325,216 325w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/6.-Icing-sugar-v2-edea1e6.jpg?quality=90&amp;webp=true&amp;fit=375,250 375w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/6.-Icing-sugar-v2-edea1e6.jpg?quality=90&amp;webp=true&amp;fit=650,433 650w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/6.-Icing-sugar-v2-edea1e6.jpg?quality=90&amp;webp=true&amp;fit=750,500 750w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/6.-Icing-sugar-v2-edea1e6.jpg?quality=90&amp;webp=true&amp;fit=975,649 975w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/6.-Icing-sugar-v2-edea1e6.jpg?quality=90&amp;webp=true&amp;fit=1000,666 1000w"/><source data-testid="image-source" sizes="(min-width: 992px) 940px,(min-width: 768px) 728px,(min-width: 544px) 556px,calc(100vw - 20px)" srcSet="https://images.immediate.co.uk/production/volatile/sites/30/2025/02/6.-Icing-sugar-v2-edea1e6.jpg?quality=90&amp;fit=325,216 325w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/6.-Icing-sugar-v2-edea1e6.jpg?quality=90&amp;fit=375,250 375w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/6.-Icing-sugar-v2-edea1e6.jpg?quality=90&amp;fit=650,433 650w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/6.-Icing-sugar-v2-edea1e6.jpg?quality=90&amp;fit=750,500 750w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/6.-Icing-sugar-v2-edea1e6.jpg?quality=90&amp;fit=975,649 975w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/6.-Icing-sugar-v2-edea1e6.jpg?quality=90&amp;fit=1000,666 1000w"/><img class="image__img" src="https://images.immediate.co.uk/production/volatile/sites/30/2025/02/6.-Icing-sugar-v2-edea1e6.jpg?quality=90&amp;fit=700,466" alt="Icing sugar being mixed in glass bowl" data-item-name="Icing sugar being mixed in glass bowl" title="Banana bread recipe" style="aspect-ratio:1 / 0.6661290322580645;object-fit:contain" loading="lazy" width="700" height="466.2903225806452" data-testid="image-img"/></picture></div></div></div></li><li class="method-steps__list-item"><h3 class="method-steps__item-heading heading-5">step 7</h3><div class="editor-content"><p>Drizzle the icing across the top of the cake and decorate with a handful of banana chips.</p><div class="image chromatic-ignore" data-testid="image"><div class="image__container" style="max-width:700px" data-testid="image-container"><picture class="image__picture" data-testid="image-picture" width="700" height="466.2903225806452"><source data-testid="image-source" type="image/webp" sizes="(min-width: 992px) 940px,(min-width: 768px) 728px,(min-width: 544px) 556px,calc(100vw - 20px)" srcSet="https://images.immediate.co.uk/production/volatile/sites/30/2025/02/7.-Icing-sugar-drizzle-v3-debe7fc.jpg?quality=90&amp;webp=true&amp;fit=325,216 325w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/7.-Icing-sugar-drizzle-v3-debe7fc.jpg?quality=90&amp;webp=true&amp;fit=375,250 375w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/7.-Icing-sugar-drizzle-v3-debe7fc.jpg?quality=90&amp;webp=true&amp;fit=650,433 650w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/7.-Icing-sugar-drizzle-v3-debe7fc.jpg?quality=90&amp;webp=true&amp;fit=750,500 750w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/7.-Icing-sugar-drizzle-v3-debe7fc.jpg?quality=90&amp;webp=true&amp;fit=975,649 975w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/7.-Icing-sugar-drizzle-v3-debe7fc.jpg?quality=90&amp;webp=true&amp;fit=1000,666 1000w"/><source data-testid="image-source" sizes="(min-width: 992px) 940px,(min-width: 768px) 728px,(min-width: 544px) 556px,calc(100vw - 20px)" srcSet="https://images.immediate.co.uk/production/volatile/sites/30/2025/02/7.-Icing-sugar-drizzle-v3-debe7fc.jpg?quality=90&amp;fit=325,216 325w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/7.-Icing-sugar-drizzle-v3-debe7fc.jpg?quality=90&amp;fit=375,250 375w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/7.-Icing-sugar-drizzle-v3-debe7fc.jpg?quality=90&amp;fit=650,433 650w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/7.-Icing-sugar-drizzle-v3-debe7fc.jpg?quality=90&amp;fit=750,500 750w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/7.-Icing-sugar-drizzle-v3-debe7fc.jpg?quality=90&amp;fit=975,649 975w,https://images.immediate.co.uk/production/volatile/sites/30/2025/02/7.-Icing-sugar-drizzle-v3-debe7fc.jpg?quality=90&amp;fit=1000,666 1000w"/><img class="image__img" src="https://images.immediate.co.uk/production/volatile/sites/30/2025/02/7.-Icing-sugar-drizzle-v3-debe7fc.jpg?quality=90&amp;fit=700,466" alt="Icing being drizzled on banana bread loaf" data-item-name="Icing being drizzled on banana bread loaf" title="Banana bread recipe" style="aspect-ratio:1 / 0.6661290322580645;object-fit:contain" loading="lazy" width="700" height="466.2903225806452" data-testid="image-img"/></picture></div></div></div></li></ul></section></div></div><div class="post__content-end row hidden-print"><div class="col-12"><div class="editor-content mb-lg" data-placement="Summary"><h2 id="frequently-asked-questions-cdf13b87">Frequently asked questions</h2><h3 id="can-i-use-plain-flour-in-banana-bread-fdba91ca">Can I use plain flour in banana bread?</h3><p>We suggest using self-raising flour as it has the raising agents already added in. However you can make your own self raising flour by mixing 100g plain flour with 1 tsp baking powder. You can scale these quantities up or down.</p><h3 id="how-many-bananas-do-you-need-to-make-banana-bread-78489dbd">How many bananas do you need to make banana bread?</h3><p>This recipe uses 2 bananas, for a vegan version why not try our <a href="/recipes/vegan-banana-bread">vegan banana bread recipe</a> or try <a href="/recipes/chocolate-chip-banana-bread">this banana bread with chocolate chips</a>.</p><p>Try a next-level indulgent twist from our sister title <a href="https://www.olivemagazine.com/recipes/baking-and-desserts/easy-banana-bread-with-peanut-butter-frosting/" target="_blank" rel="noopener">olivemagazine.com/peanut-butter-banana-bread</a>.</p></div></div></div><p class="post__publication-link hidden-print">Recipe from Good Food magazine, <!-- -->July 2012</p></div><div class="pocket hidden-print mb-md" data-placement="recipeBelowContent"><div class="mt-md"></div></div><div class="mb-lg hidden-for-md hidden-for-lg ad-slot hidden-print ad-slot__inline ad-slot--bordered" data-testid="ad-slot"><div class="ad-slot__container ad-slot__inline-container" data-testid="ad-slot__container"><div class="ad-slot__label chromatic-ignore"><span class="ad-slot__text">Ad</span></div><div id="recipe--inline--4" data-testid="ad-unit" class="ad-unit"></div></div><div><script>(window.adq = window.adq || []).push((api) => api.addSlot({"key":"inline","index":"4","searchTerm":null,"fullSearchTerm":null}));</script></div></div><div class="pocket hidden-print" data-placement="recipeContentBottom"><div class="pb-lg" id="commentsFeed" data-feature="Reactions"><h2 class="pt-md pb-md heading-2">Comments, questions and tips</h2><div id="rating"><div class="mb-xs box pa-sm" style="background-color:rgba(240, 240, 240, 1)" data-testid="box"><form novalidate="" class="form" data-form-name="Rate" data-testid="form"><div class="form-group pt-lg pb-lg text-center"><h3 class="mb-md heading-4">Rate this recipe</h3><fieldset class="rate mb-md"><legend class="sr-only">What is your star rating out of 5?</legend><label class="rate__stars" for="stars-1" data-item-name="Star"><span class="sr-only">1 star out of 5</span><input class="sr-only" id="stars-1" name="stars" type="radio" value="1"/><i class="rate__icon icon" style="width:48px;min-width:48px;height:48px;min-height:48px;animation-duration:1000ms" data-testid="icon"><svg class="icon__svg" aria-hidden="true" focusable="false" style="color:rgba(244, 191, 31, 1);fill:rgba(244, 191, 31, 1)" data-testid="icon-svg"><use xlink:href="/static/icons/base/sprite-maps/stars-b815c58f9ce6205de1c7a6f641b0e768.svg#star-outline"></use></svg></i></label><label class="rate__stars" for="stars-2" data-item-name="Star"><span class="sr-only">2 stars out of 5</span><input class="sr-only" id="stars-2" name="stars" type="radio" value="2"/><i class="rate__icon icon" style="width:48px;min-width:48px;height:48px;min-height:48px;animation-duration:1000ms" data-testid="icon"><svg class="icon__svg" aria-hidden="true" focusable="false" style="color:rgba(244, 191, 31, 1);fill:rgba(244, 191, 31, 1)" data-testid="icon-svg"><use xlink:href="/static/icons/base/sprite-maps/stars-b815c58f9ce6205de1c7a6f641b0e768.svg#star-outline"></use></svg></i></label><label class="rate__stars" for="stars-3" data-item-name="Star"><span class="sr-only">3 stars out of 5</span><input class="sr-only" id="stars-3" name="stars" type="radio" value="3"/><i class="rate__icon icon" style="width:48px;min-width:48px;height:48px;min-height:48px;animation-duration:1000ms" data-testid="icon"><svg class="icon__svg" aria-hidden="true" focusable="false" style="color:rgba(244, 191, 31, 1);fill:rgba(244, 191, 31, 1)" data-testid="icon-svg"><use xlink:href="/static/icons/base/sprite-maps/stars-b815c58f9ce6205de1c7a6f641b0e768.svg#star-outline"></use></svg></i></label><label class="rate__stars" for="stars-4" data-item-name="Star"><span class="sr-only">4 stars out of 5</span><input class="sr-only" id="stars-4" name="stars" type="radio" value="4"/><i class="rate__icon icon" style="width:48px;min-width:48px;height:48px;min-height:48px;animation-duration:1000ms" data-testid="icon"><svg class="icon__svg" aria-hidden="true" focusable="false" style="color:rgba(244, 191, 31, 1);fill:rgba(244, 191, 31, 1)" data-testid="icon-svg"><use xlink:href="/static/icons/base/sprite-maps/stars-b815c58f9ce6205de1c7a6f641b0e768.svg#star-outline"></use></svg></i></label><label class="rate__stars" for="stars-5" data-item-name="Star"><span class="sr-only">5 stars out of 5</span><input class="sr-only" id="stars-5" name="stars" type="radio" value="5"/><i class="rate__icon icon" style="width:48px;min-width:48px;height:48px;min-height:48px;animation-duration:1000ms" data-testid="icon"><svg class="icon__svg" aria-hidden="true" focusable="false" style="color:rgba(244, 191, 31, 1);fill:rgba(244, 191, 31, 1)" data-testid="icon-svg"><use xlink:href="/static/icons/base/sprite-maps/stars-b815c58f9ce6205de1c7a6f641b0e768.svg#star-outline"></use></svg></i></label></fieldset><div class="form-feedback body-copy-extra-small body-copy-bold"></div></div></form></div></div><div class="mb-sm box pa-sm" style="background-color:rgba(240, 240, 240, 1)" data-testid="box"><div class="pt-xxs pb-sm text-center full-width"><form novalidate="" class="form" data-form-name="Reaction" data-testid="form"><div class="form-group"><h3 class="mb-md m