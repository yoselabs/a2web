S__">{"licenceKey":"0c18e53b610964fac175fe0e757adc30557e79b7","playerId":"5e7JRLeY","playerIdContent":"","playerIdListings":"","loaderUrl":"https://cdn.greenvideo.io/players/gv.js","podcastPlayerId":"DAq6Bpqn","podcastLoaderUrl":"https://cdn.greenvideo.io/podcast/gp.js","carouselPlayerId":"","carouselLoaderUrl":"https://cdn.greenvideo.io/carousel/gfc.js"}</script><script type="application/json" id="__POST_CONTENT__">{"page":null,"callout":null,"client":"bbcgoodfood","entity":"recipe","postId":"233531","published":null,"siteTitle":"Good Food","slug":"brilliant-banana-loaf","uid":"recipes~brilliant-banana-loaf","title":"Banana bread","status":"published","isPrivate":false,"postType":"recipe","isPremium":false,"contentWallExperience":{"enabled":false,"theme":"default"},"recommendedPost":{"heading":"More like this","getItemsUrl":"/api/editorial/search/recommended-items?limit=1&clientId=233531&search=Banana%20bread&postType=recipe&category=recipes"},"authorBioShow":false,"authorPrefix":null,"authors":[{"name":"Good Food team","avatar":null,"bio":"We are the UK’s number one food brand","facebook":null,"instagram":null,"jobTitle":null,"id":null,"suffix":null,"twitter":null,"url":"/author/goodfood"}],"description":"<p>A cross between banana bread and a drizzle cake, this easy banana loaf recipe is a quick bake that can be frozen. It's great for using up overripe bananas, too.</p>","endSummary":[{"type":"html","data":{"value":"<h2 id=\"frequently-asked-questions-cdf13b87\">Frequently asked questions</h2><h3 id=\"can-i-use-plain-flour-in-banana-bread-fdba91ca\">Can I use plain flour in banana bread?</h3><p>We suggest using self-raising flour as it has the raising agents already added in. However you can make your own self raising flour by mixing 100g plain flour with 1 tsp baking powder. You can scale these quantities up or down.</p><h3 id=\"how-many-bananas-do-you-need-to-make-banana-bread-78489dbd\">How many bananas do you need to make banana bread?</h3><p>This recipe uses 2 bananas, for a vegan version why not try our <a href=\"/recipes/vegan-banana-bread\">vegan banana bread recipe</a> or try <a href=\"/recipes/chocolate-chip-banana-bread\">this banana bread with chocolate chips</a>.</p><p>Try a next-level indulgent twist from our sister title <a href=\"https://www.olivemagazine.com/recipes/baking-and-desserts/easy-banana-bread-with-peanut-butter-frosting/\" target=\"_blank\" rel=\"noopener\">olivemagazine.com/peanut-butter-banana-bread</a>.</p>"}}],"introduction":[[{"type":"html","data":{"value":"<p>Make mornings easier and tastier with these <a href=\"https://www.bbcgoodfood.com/recipes/banana-bread-baked-oats\">banana bread baked oats </a></p>"}}]],"promo":null,"userRatings":{"avg":4.5,"total":2299,"isHalfStar":false,"commentCount":0},"isSaveable":true,"sponsor":null,"relatedItems":null,"plantOverview":null,"openWebSettings":{"disableSocialReviews":false,"disableReadOnly":false},"globalOpenWebSettings":null,"openWebRatingEnabled":false,"ediplayerSettings":null,"ingredients":[{"ingredients":[{"main":false,"glossaryLink":"/glossary/butter-glossary","imperialQuantity":5,"metricQuantity":140,"imperialUnit":"oz","ingredientText":"butter","metricUnit":"g","note":"softened, plus extra for the tin","quantityText":"140g","term":{"slug":"butter","display":"butter"}},{"main":false,"glossaryLink":"/glossary/sugar-glossary","imperialQuantity":5,"metricQuantity":140,"imperialUnit":"oz","ingredientText":"caster sugar","metricUnit":"g","quantityText":"140g","term":{"slug":"caster-sugar","display":"caster sugar"}},{"main":false,"glossaryLink":"/glossary/egg-glossary","metricQuantity":2,"ingredientText":"eggs","note":"beaten","quantityText":"2 large","term":{"slug":"large-egg","display":"large egg"}},{"main":false,"glossaryLink":"/glossary/flour-glossary","imperialQuantity":5,"metricQuantity":140,"imperialUnit":"oz","ingredientText":"self-raising flour","metricUnit":"g","quantityText":"140g","term":{"slug":"self-raising-flour","display":"self-raising flour"}},{"main":false,"glossaryLink":"/glossary/baking-powder-glossary","metricQuantity":1,"ingredientText":"baking powder","metricUnit":"tsp","quantityText":"1 tsp","term":{"slug":"baking-powder","display":"baking powder"}},{"main":true,"glossaryLink":"/glossary/banana-glossary","metricQuantity":2,"ingredientText":"bananas","note":"mashed","quantityText":"2 very ripe ","term":{"slug":"banana","display":"banana"}},{"main":false,"glossaryLink":"/glossary/sugar-glossary","imperialQuantity":2,"metricQuantity":50,"imperialUnit":"oz","ingredientText":"icing sugar","metricUnit":"g","quantityText":"50g","term":{"slug":"icing-sugar","display":"icing sugar"}},{"main":false,"glossaryLink":"/glossary/banana-glossary","ingredientText":"dried banana chips","note":"for decoration","quantityText":"handful","term":{"slug":"banana","display":"banana"}}]}],"reverseIngredients":false,"nutritions":[{"label":"kcal","value":268,"unit":"","additionalText":"","low":false,"high":false},{"label":"fat","value":13,"unit":"g","additionalText":"","low":false,"high":false},{"label":"saturates","value":8,"unit":"g","additionalText":"","low":false,"high":false},{"label":"carbs","value":34,"unit":"g","additionalText":"","low":false,"high":false},{"label":"sugars","value":24,"unit":"g","additionalText":"","low":false,"high":false},{"label":"fibre","value":1,"unit":"g","additionalText":"","low":false,"high":false},{"label":"protein","value":3,"unit":"g","additionalText":"","low":false,"high":false},{"label":"salt","value":0.5,"unit":"g","additionalText":"","low":false,"high":false}],"nutritionalInfoCaption":"Nutrition: per slice (10)","planning":[{"display":"Freezable (un-iced)","slug":"freezable"}],"skillLevel":"Easy","cookAndPrepTime":{"preparationMin":0,"preparationMax":900,"cookingMin":0,"cookingMax":3000,"total":3900,"note":""},"methodSteps":[{"type":"step","content":[{"type":"html","data":{"value":"<p>Heat oven to 180C/160C fan/gas 4. Butter a 2lb <a href=\"https://www.bbcgoodfood.com/howto/guide/baking-equipment\">loaf tin</a> and line the base and sides with baking parchment.</p>"}},{"type":"image","data":{"url":"https://images.immediate.co.uk/production/volatile/sites/30/2013/04/1.-Lining-tin-0b46cdd.jpg","width":1000,"height":667,"title":"Banana bread recipe","alt":"Loaf tin lined with baking parchment","aspectRatio":0.6661290322580645,"caption":null,"contain":"all","sourceName":null}}]},{"type":"step","content":[{"type":"html","data":{"value":"<p><a href=\"https://www.bbcgoodfood.com/content/test-five-best-food-processors\">Cream</a> 140g softened butter and 140g caster sugar until light and fluffy, then slowly add 2 beaten large eggs with a little of the 140g flour.</p>"}},{"type":"image","data":{"url":"https://images.immediate.co.uk/production/volatile/sites/30/2013/04/2.-Creamed-sugar-and-egg-v2-61a46fb.jpg","width":1000,"height":667,"title":"Banana bread recipe","alt":"Creaming butter and egg in a glass bowl","aspectRatio":0.6661290322580645,"caption":null,"contain":"all","sourceName":null}}]},{"type":"step","content":[{"type":"html","data":{"value":"<p>Fold in the remaining flour, 1 tsp baking powder and 2 mashed bananas.</p>"}},{"type":"image","data":{"url":"https://images.immediate.co.uk/production/volatile/sites/30/2013/04/4.-Add-flour-banana-v2-4e08754.jpg","width":1000,"height":667,"title":"Banana bread recipe","alt":"Mashed banana and flour mixed in a glass bowl","aspectRatio":0.6661290322580645,"caption":null,"contain":"all","sourceName":null}}]},{"type":"step","content":[{"type":"html","data":{"value":"<p>Pour the mixture into the prepared tin and bake for about 50 mins, or until cooked through. Check the loaf at 5-min intervals from around 30-40 mins in the oven by testing it with a skewer (it should be able to be inserted and removed cleanly), as the time may vary depending on the shape of your loaf tin.</p>"}},{"type":"image","data":{"url":"https://images.immediate.co.uk/production/volatile/sites/30/2025/02/5.-Mixture-in-tin-v2-64c2ad3.jpg","width":1000,"height":667,"title":"5.-Mixture-in-tin-v2","alt":"Cake mixture in lined tin","aspectRatio":0.6661290322580645,"caption":null,"contain":"all","sourceName":null}}]},{"type":"step","content":[{"type":"html","data":{"value":"<p>Cool in the tin for 10 mins, then remove to a <a href=\"https://www.bbcgoodfood.com/content/kimberley-wilsons-top-five-cooling-racks\">wire rack</a>.</p>"}}]},{"type":"step","content":[{"type":"html","data":{"value":"<p>Mix 50g icing sugar with 2-3 tsp water to make a runny icing.</p>"}},{"type":"image","data":{"url":"https://images.immediate.co.uk/production/volatile/sites/30/2025/02/6.-Icing-sugar-v2-edea1e6.jpg","width":1000,"height":666,"title":"Banana bread recipe","alt":"Icing sugar being mixed in glass bowl","aspectRatio":0.6661290322580645,"caption":null,"contain":"all","sourceName":null}}]},{"type":"step","content":[{"type":"html","data":{"value":"<p>Drizzle the icing across the top of the cake and decorate with a handful of banana chips.</p>"}},{"type":"image","data":{"url":"https://images.immediate.co.uk/production/volatile/sites/30/2025/02/7.-Icing-sugar-drizzle-v3-debe7fc.jpg","width":1000,"height":667,"title":"Banana bread recipe","alt":"Icing being drizzled on banana bread loaf","aspectRatio":0.6661290322580645,"caption":null,"contain":"all","sourceName":null}}]}],"servings":"Cuts into 8-10 slices","diet":[],"recommended":{"getItemsUrl":"/api/editorial/card-items-by-clientid/226842,226476,268818"},"recommendedLink":{"heading":"Our Most Popular Alternative","getItemsUrl":"/api/editorial/search/recommended-items?limit=1&clientId=233531&search=Banana%20bread&postType=recipe&category=recipes"},"publication":{"message":"Recipe from Good Food magazine, ","src":"/search?publication=july-2012","srcText":"July 2012"},"headerConfig":{"showPrintButton":true},"breadcrumbs":[{"label":"Home","url":"https://www.bbcgoodfood.com:443"},{"label":"Recipes","url":"https://www.bbcgoodfood.com/recipes"},{"label":"Banana bread"}],"seoMetadata":{"title":"Banana bread","description":"A cross between banana bread and a drizzle cake, this easy banana loaf recipe is a quick bake that can be frozen. It's great for using up overripe bananas, too.","metaTitle":"Banana bread recipe","metaDescription":"Bake a classic banana bread with this easy recipe, perfect for everyday baking and occasions. Find more cake recipes at BBC Good Food.","image":{"aspectRatio":0.9087301587301587,"height":400,"width":440,"alt":"Sliced banana bread topped with drizzle and banana chips on a serving plate","title":"Banana bread","url":"https://images.immediate.co.uk/production/volatile/sites/30/2020/06/recipe-image-legacy-id-1273522_8-a6b9246.jpg","sourceName":null},"type":"article","robots":"","canonicalUrl":"https://www.bbcgoodfood.com/recipes/brilliant-banana-loaf"},"speedCurveLux":{"label":"recipe","data":{"layout-variant":"masthead"}},"pageUrl":"https://www.bbcgoodfood.com/recipes/brilliant-banana-loaf","canonicalUrl":"https://www.bbcgoodfood.com/recipes/brilliant-banana-loaf","permutiveModel":{"category":["recipes"],"subcategory":["recipe"],"channel":"recipes","title":"Banana bread","article":{"id":"233531","description":"A cross between banana bread and a drizzle cake, this easy banana loaf recipe is a quick bake that can be frozen. It's great for using up overripe bananas, too.","type":"recipe","author":"Good Food team","tags":["Athletes","Banana bread","Coffee morning","Drizzle","Frosting","Fruit cake","Glut","Good Food","Icing","Loaf tin","Make ahead","Olympics","Overripe","Team gb","Traditional","Weekend","Winning treats"]},"recipe":{"cooking_time":3000,"ingredients":["butter,","caster sugar","eggs,","self-raising flour","baking powder","bananas,","icing sugar","dried banana chips,"],"keywords":["athletes","banana-bread","coffee-morning","drizzle","frosting","fruit-cake","glut","good-food","icing","loaf-tin","make-ahead","olympics","overripe","team-gb","traditional","weekend","winning-treats"],"nutrition_info":["kcal 268","fat 13g","saturates 8g","carbs 34g","sugars 24g","fibre 1g","protein 3g","salt 0.5g"],"prep_time":900,"serves":10,"courses":["afternoon-tea","dessert"],"diet_types":[],"skill_level":"easy","post_dates":"2025-03-31T17:10:12+00:00"}},"socialShare":{"platforms":[],"emailSubject":"Yum!","emailBody":"Good Food every day...","twitterHandle":"@bbcgoodfood","fbAuthorizeCode":"31296838546","title":"Banana%20bread","tweet":"Banana%20bread","disabled":false,"url":"https://www.bbcgoodfood.com/recipes/brilliant-banana-loaf"},"schema":{"@context":"https://schema.org","@id":"https://www.bbcgoodfood.com/recipes/brilliant-banana-loaf#Recipe","@type":"Recipe","description":"A cross between banana bread and a drizzle cake, this easy banana loaf recipe is a quick bake that can be frozen. It's great for using up overripe bananas, too.","image":[{"@type":"ImageObject","url":"https://images.immediate.co.uk/production/volatile/sites/30/2020/06/recipe-image-legacy-id-1273522_8-a6b9246.jpg?resize=440,400","width":440,"height":400}],"mainEntityOfPage":{"@type":"WebPage","@id":"https://www.bbcgoodfood.com/recipes/brilliant-banana-loaf"},"name":"Banana bread","url":"https://www.bbcgoodfood.com/recipes/brilliant-banana-loaf","author":[{"@type":"Person","name":"Good Food team","url":"https://www.bbcgoodfood.com/author/goodfood"}],"dateModified":"2025-09-20T12:49:34+01:00","datePublished":"2025-03-31T18:10:12+01:00","headline":"Banana bread","keywords":"Athletes, Banana bread, Coffee morning, Drizzle, Frosting, Fruit cake, Glut, Good Food, Icing, Loaf tin, Make ahead, Olympics, Overripe, Team gb, Traditional, Weekend, Winning treats","publisher":{"@type":"Organization","name":"Good Food","url":"https://www.bbcgoodfood.com","logo":{"@type":"ImageObject","height":325,"url":"https://images.immediate.co.uk/production/volatile/sites/30/2026/02/goodfood.logo-f37096c.png?resize=1312,325","width":1312}},"cookTime":"PT50M","nutrition":{"@type":"NutritionInformation","calories":"268 calories","fatContent":"13 grams fat","saturatedFatContent":"8 grams saturated fat","carbohydrateContent":"34 grams carbohydrates","sugarContent":"24 grams sugar","fiberContent":"1 grams fiber","proteinContent":"3 grams protein","sodiumContent":"0.5 milligram of sodium"},"prepTime":"PT15M","recipeCategory":"Afternoon tea, Dessert","recipeCuisine":"British","recipeIngredient":["140g butter softened, plus extra for the tin","140g caster sugar","2 large eggs beaten","140g self-raising flour","1 tsp baking powder","2 very ripe  bananas mashed","50g icing sugar","handful dried banana chips for decoration"],"recipeInstructions":[{"@type":"HowToStep","text":"Heat oven to 180C/160C fan/gas 4. Butter a 2lb loaf tin and line the base and sides with baking parchment.","image":{"@type":"ImageObject","url":"https://images.immediate.co.uk/production/volatile/sites/30/2013/04/1.-Lining-tin-0b46cdd.jpg","width":1000,"height":667}},{"@type":"HowToStep","text":"Cream 140g softened butter and 140g caster sugar until light and fluffy, then slowly add 2 beaten large eggs with a little of the 140g flour.","image":{"@type":"ImageObject","url":"https://images.immediate.co.uk/production/volatile/sites/30/2013/04/2.-Creamed-sugar-and-egg-v2-61a46fb.jpg","width":1000,"height":667}},{"@type":"HowToStep","text":"Fold in the remaining flour, 1 tsp baking powder and 2 mashed bananas.","image":{"@type":"ImageObject","url":"https://images.immediate.co.uk/production/volatile/sites/30/2013/04/4.-Add-flour-banana-v2-4e08754.jpg","width":1000,"height":667}},{"@type":"HowToStep","text":"Pour the mixture into the prepared tin and bake for about 50 mins, or until cooked through. Check the loaf at 5-min intervals from around 30-40 mins in the oven by testing it with a skewer (it should be able to be inserted and removed cleanly), as the time may vary depending on the shape of your loaf tin.","image":{"@type":"ImageObject","url":"https://images.immediate.co.uk/production/volatile/sites/30/2025/02/5.-Mixture-in-tin-v2-64c2ad3.jpg","width":1000,"height":667}},{"@type":"HowToStep","text":"Cool in the tin for 10 mins, then remove to a wire rack."},{"@type":"HowToStep","text":"Mix 50g icing sugar with 2-3 tsp water to make a runny icing.","image":{"@type":"ImageObject","url":"https://images.immediate.co.uk/production/volatile/sites/30/2025/02/6.-Icing-sugar-v2-edea1e6.jpg","width":1000,"height":666}},{"@type":"HowToStep","text":"Drizzle the icing across the top of the cake and decorate with a handful of banana chips.","image":{"@type":"ImageObject","url":"https://images.immediate.co.uk/production/volatile/sites/30/2025/02/7.-Icing-sugar-drizzle-v3-debe7fc.jpg","width":1000,"height":667}}],"recipeYield":"Cuts into 8-10 slices","totalTime":"PT1H5M"},"targeting":{"gtm":{"cat":["recipes"],"channel":"recipes","format":"video","pageid":"233531","primary_cat":"recipes","subcat":"recipe","author":"Good Food team","publish_date":"2025-03-31T17:10:12+00:00","template":"recipe","taxonomies":{"posttag":["athletes","banana-bread","coffee-morning","drizzle","frosting","fruit-cake","glut","good-food","icing","loaf-tin","make-ahead","olympics","overripe","team-gb","traditional","weekend","winning-treats"],"cuisine":["british"],"meal-type":["afternoon-tea","dessert"]}},"dfp":{"configuration":"live","cat":["recipes"],"channel":"recipes","format":"video","pageid":"233531","primary_cat":"recipes","subcat":"recipe","posttag":["athletes","banana-bread","coffee-morning","drizzle","frosting","fruit-cake","glut","good-food","icing","loaf-tin","make-ahead","olympics","overripe","team-gb","traditional","weekend","winning-treats"],"cuisine":["british"],"meal-type":["afternoon-tea","dessert"]}},"bodyClass":{"bodyClassName":"layout-recipe","layoutType":"recipe"},"affiliateMessage":null,"image":{"aspectRatio":0.9087301587301587,"height":400,"width":440,"alt":"Sliced banana bread topped with drizzle and banana chips on a serving plate","title":"Banana bread","url":"https://images.immediate.co.uk/production/volatile/s