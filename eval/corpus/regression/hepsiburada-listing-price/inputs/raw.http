lar var.\\nHızlı ve sorunsuz gönderim için teşekkür ederim. Ayrıca piyasanın en ucuzu idi.\",\"firstname\":\"Ü\",\"lastname\":\"A\"},\"userContentCountWithMedia\":13},\"isSemantic\":false,\"definition\":{\"id\":372,\"name\":\"Bluetooth Kulaklıklar\"},\"mainCategory\":{\"id\":16218,\"name\":\"Bluetooth Kulaklıklar\"},\"cardSize\":\"L\",\"CardSizePx\":124,\"al_p\":\"uSOsQL94TO/V3UE61D5sX6W3IPRQYWbb/KBpH5hJz4cerzEb8GauXBFSBsVFxX9nxEUnCRoHKJ0veyoruAFaDoQGoidn67OVF6ypNO0wqwETByLAoEZ5a3oip29+95L5GPvsDxkpULJYp7c1iVj91hqw8dO6wDRpIOtPJZ5QEog=\",\"isSplitted\":false,\"isMirosProduct\":0,\"reasonDetails\":\"\",\"isExistColorVariant\":true,\"colorVariantCount\":2,\"installmentLimit\":9},{\"productId\":\"HBC0000AARF96\",\"brand\":\"Lenovo\",\"customerReviewCount\":66,\"customerReviewScore\":5,\"customerReviewRating\":4.6,\"boostingFactors\":[\"en-avantajli-fiyatlar\"],\"variantList\":[{\"sku\":\"HBCV0000AARF97\",\"name\":\"Lenovo E310 Beyaz ''True'' Wireless Stereo Kulaklık Kulakiçi Müzik Dinleyebilme Özelliği ile GXD1Q65145\",\"url\":\"/lenovo-e310-beyaz-true-wireless-stereo-kulaklik-kulakici-muzik-dinleyebilme-ozelligi-ile-gxd1q65145-p-HBCV0000AARF97\",\"isDefault\":true,\"procurable\":true,\"adInfo\":\"\",\"adShowId\":\"\",\"isMultiSeller\":true,\"listing\":{\"priceInfo\":{\"price\":700,\"priceTextColor\":\"\",\"originalPrice\":890,\"discountRate\":21,\"discountType\":\"Discount\"},\"isPreOrder\":false,\"inStockDate\":null,\"merchantName\":\"Bölge-İletişim\",\"merchantId\":\"0df2d338-608f-4d4b-8877-b1228e546ec5\",\"listingId\":\"29867785-bae9-421c-b095-9ba7430aff55\",\"tagList\":null,\"labels\":null,\"categorizedLabels\":{\"incentiveToBuy\":null,\"valueAddedService\":null,\"campaign\":null,\"winner\":null,\"affordability\":null,\"imageLabel\":[{\"tagName\":\"en-avantajli-fiyatlar\",\"textColor\":\"\",\"imageUrl\":\"https://images.hepsiburada.net/banners/s/1/104-105/app134056176801991801.png\",\"badgeImageUrl\":\"https://images.hepsiburada.net/banners/s/1/104-105/app1340561768