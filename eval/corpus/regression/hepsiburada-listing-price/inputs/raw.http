alse,\"adsUniqueId\":\"\",\"merchantId\":\"\",\"adsCampaignId\":\"\",\"adsSupplierId\":\"\"},{\"sku\":\"HBCV000072PXK5\",\"name\":\"Redmi Buds 6 Play - Beyaz Kulakiçi Kulaklık TWS (Xiaomi Türkiye Garantili)\",\"url\":\"/redmi-buds-6-play-beyaz-kulakici-kulaklik-tws-xiaomi-turkiye-garantili-p-HBCV000072PXK5\",\"isDefault\":false,\"procurable\":true,\"adInfo\":\"\",\"adShowId\":\"\",\"isMultiSeller\":false,\"listing\":{\"priceInfo\":{\"price\":679.22,\"priceTextColor\":\"\",\"originalPrice\":679.22,\"discountRate\":0,\"discountType\":\"NoDiscount\"},\"isPreOrder\":false,\"inStockDate\":null,\"merchantName\":\"\",\"merchantId\":\"\",\"listingId\":\"e84804d1-c1a9-47c3-80f3-ff1c4293d2dc\",\"tagList\":null,\"labels\":null,\"categorizedLabels\":{\"incentiveToBuy\":null,\"valueAddedService\":null,\"campaign\":null,\"winner\":null,\"affordability\":null,\"imageLabel\":null,\"hepsiMoney\":null},\"jetDeliveryCities\":null,\"jetDelivery\":false,\"expressDeliveryWarehouses\":null,\"expressDelivery\":false,\"cityBasedCutOffEnabled\":false,\"campaignText\":\"\",\"campaigns\":null,\"minimumPrices\":null,\"shippingProfileId\":\"\",\"shipmentDay\":0,\"aiBasedShipmentDay\":0,\"warehouseId\":\"\",\"availableWarehouses\":null,\"campaignPriceInfo\":null,\"nextEligibleCampaign\":null},\"images\":[{\"link\":\"https://productimages.hepsiburada.net/s/777/{size}/110000792964462.jpg\",\"isDefault\":true,\"height\":389,\"width\":314}],\"properties\":{\"Renk\":{\"displayValue\":\"Beyaz\",\"value\":\"Beyaz\"}},\"energyClassInfo\":null,\"winnerFreight\":0,\"trackingInfo\":null,\"taxVatRate\":0,\"adsCampaignOwnerType\":\"\",\"isPromoted\":false,\"adsUniqueId\":\"\",\"merchantId\":\"\",\"adsCampaignId\":\"\",\"adsSupplierId\":\"\"}],\"displayOptions\":{\"isAdultProduct\":false,\"hasColorVariant\":true},\"hasVariant\":true,\"userContentInfo\":{\"bestReview\":{\"content\":\"Harika ses kalitesi ve genel olarak mükemmel bir performans, üstelik bu kadar uygun fiyata! Gerçekten çok şaşırdım. Daha çok spor salonu ve antrenmanlar için almıştım, çünkü asıl kullandığım birinci nesil AirPods’ların pili yıllar içinde artık azalmaya başladı. Ama size gönül rahatlığıyla söyleyebilirim ki, bu kulaklıklar müzik dinlemek, podcast’ler için ve spor yapmak adına fazlasıyla yeterli ve harika.\\n\\nKulakta çok rahat oturuyor, adeta hiç hissetmiyorum bile. Seçimimi bunlardan yana yaptım çünkü küçük ve kompakt bir model istiyordum. Xiaomi mağazalarında tükenmişti, bu yüzden siparişimi Hepsiburada üzerinden verdim ve her zamanki gibi teslimat inanılmaz hızlıydı — akşam sipariş verdim, sabah elime ulaştı.\\n\\nBöylesine hızlı ve kaliteli hizmet için çok teşekkür ederim, her zamanki gibi harikasınız!\\nGünlük kullanım için bu kadar uygun fiyata gerçekten mükemmel kulaklıklar!\",\"firstname\":\"K\",\"lastname\":\"D\"},\"userContentCountWithMedia\":363},\"isSemantic\":false,\"definition\":{\"id\":372,\"name\":\"Bluetooth Kulaklıklar\"},\"mainCategory\":{\"id\":16218,\"name\":\"Bluetooth Kulaklıklar\"},\"cardSize\":\"L\",\"CardSizePx\":144,\"al_p\":\"RCT8Gq5JqMJMt/F+xsJDxUyG1pE2EmRhpnFCJN6UL9kBcfw98c0PXmHTpFqYRfULpEFkc16KwRielH6/FESiwb9x9o3AScvR60dJRqRrkFoqeNWxRYGpm8iyi33h3ad9p8dkQ2YjaiWIG4x9WmuVgXL0vznbfM5NJYp0lP9jD1M=\",\"isSplitted\":false,\"isMirosProduct\":0,\"reasonDetails\":\"\",\"isExistColorVariant\":true,\"colorVariantCount\":4,\"installmentLimit\":9},{\"productId\":\"HBC00009Z66PA\",\"brand\":\"Apple\",\"customerReviewCount\":1263,\"customerReviewScore\":5,\"customerReviewRating\":4.7,\"boostingFactors\":[\"avantajli-fiyatlar\"],\"variantList\":[{\"sku\":\"HBCV00009Z66PB\",\"name\":\"Apple Airpods Pro 3 Kulakiçi TWS Bluetooth Kulaklık Aktif Gürültü Önleme Suya Dayanıklı\",\"url\":\"/apple-airpods-pro-3-kulakici-tws-bluetooth-kulaklik-aktif-gurultu-onleme-suya-dayanikli-pm-HBC00009Z66PA\",\"isDefault\":true,\"procurable\":true,\"adInfo\":\"\",\"adShowId\":\"\",\"isMultiSeller\":true,\"listing\":{\"priceInfo\":{\"price\":11640.5,\"priceTextColor\":\"\",\"originalPrice\":11640.5,\"