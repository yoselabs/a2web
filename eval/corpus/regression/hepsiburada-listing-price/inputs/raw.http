ampaign\":null},\"images\":[{\"link\":\"https://productimages.hepsiburada.net/s/777/{size}/110001203117605.jpg\",\"isDefault\":true,\"height\":746,\"width\":1033}],\"properties\":{\"Renk\":{\"displayValue\":\"Gri\",\"value\":\"Gri\"}},\"energyClassInfo\":null,\"winnerFreight\":0,\"trackingInfo\":null,\"taxVatRate\":0,\"adsCampaignOwnerType\":\"\",\"isPromoted\":false,\"adsUniqueId\":\"\",\"merchantId\":\"\",\"adsCampaignId\":\"\",\"adsSupplierId\":\"\"}],\"displayOptions\":{\"isAdultProduct\":false,\"hasColorVariant\":true},\"hasVariant\":true,\"userContentInfo\":{\"bestReview\":{\"content\":\"Kalite kendini belli ediyor.\\nSamsung Buds2Pro ve Mi Earbuds Basic 2 kullanıcısı olarak söylemeliyim ki müzik kalitesi Buds2Pro ile aynı; çok net ve pürüzsüz, dinlemesi keyifli ancak derin bası Mi gibi değil. Bas olayını merak ediyordum. Mi'de müzik dinlemeyi Samsung'dan daha çok seviyorum lâkin konuşma konusunda Samsung çok çok daha iyi.\\nBu kulaklığın konuşma kalitesi ise Samsung Buds2 Pro'nun konuşma kalitesinden daha iyi.\\nSamsung telefon kullanmadığımdan mıdır bilmiyorum ses çok yüksek değildi, bilgisayarda ki ses ise yeterliydi. Dışarının sesini duymuyorsun.\\nBilgisayarda video izlerken gecikme hissetmedim.\\nYazılımsal özelliklerini kullanmak için Samsung telefon gerekiyor.\\nKutusundan kablo çıkmıyor, büyük ve küçük olmak üzere kulak içi yedek silikonlar var.\\nHızlı ve sorunsuz gönderim için teşekkür ederim. Ayrıca piyasanın en ucuzu idi.\",\"firstname\":\"Ü\",\"lastname\":\"A\"},\"userContentCountWithMedia\":13},\"isSemantic\":false,\"definition\":{\"id\":372,\"name\":\"Bluetooth Kulaklıklar\"},\"mainCategory\":{\"id\":16218,\"name\":\"Bluetooth Kulaklıklar\"},\"cardSize\":\"L\",\"CardSizePx\":124,\"al_p\":\"uSOsQL94TO/V3UE61D5sX6W3IPRQYWbb/KBpH5hJz4cerzEb8GauXBFSBsVFxX9nxEUnCRoHKJ0veyoruAFaDoQGoidn67OVF6ypNO0wqwETByLAoEZ5a3oip29+95L5GPvsDxkpULJYp7c1iVj91hqw8dO6wDRpIOtPJZ5QEog=\",\"isSplitted\":false,\"isMirosProduct\":0,\"reasonDetails\":\"\",\"isExistColorVaria