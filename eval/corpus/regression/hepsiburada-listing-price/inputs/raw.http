l},\"images\":[{\"link\":\"https://productimages.hepsiburada.net/s/777/{size}/110001203077667.jpg\",\"isDefault\":true,\"height\":746,\"width\":1033}],\"properties\":{\"Renk\":{\"displayValue\":\"Siyah\",\"value\":\"Siyah\"}},\"energyClassInfo\":null,\"winnerFreight\":0,\"trackingInfo\":null,\"taxVatRate\":0,\"adsCampaignOwnerType\":\"\",\"isPromoted\":false,\"adsUniqueId\":\"\",\"merchantId\":\"\",\"adsCampaignId\":\"\",\"adsSupplierId\":\"\"}],\"displayOptions\":{\"isAdultProduct\":false,\"hasColorVariant\":true},\"hasVariant\":true,\"userContentInfo\":{\"bestReview\":{\"content\":\"Kalite kendini belli ediyor.\\nSamsung Buds2Pro ve Mi Earbuds Basic 2 kullanıcısı olarak söylemeliyim ki müzik kalitesi Buds2Pro ile aynı; çok net ve pürüzsüz, dinlemesi keyifli ancak derin bası Mi gibi değil. Bas olayını merak ediyordum. Mi'de müzik dinlemeyi Samsung'dan daha çok seviyorum lâkin konuşma konusunda Samsung çok çok daha iyi.\\nBu kulaklığın konuşma kalitesi ise Samsung Buds2 Pro'nun konuşma kalitesinden daha iyi.\\nSamsung telefon kullanmadığımdan mıdır bilmiyorum ses çok yüksek değildi, bilgisayarda ki ses ise yeterliydi. Dışarının sesini duymuyorsun.\\nBilgisayarda video izlerken gecikme hissetmedim.\\nYazılımsal özelliklerini kullanmak için Samsung telefon gerekiyor.\\nKutusundan kablo çıkmıyor, büyük ve küçük olmak üzere kulak içi yedek silikonlar var.\\nHızlı ve sorunsuz gönderim için teşekkür ederim. Ayrıca piyasanın en ucuzu idi.\",\"firstname\":\"Ü\",\"lastname\":\"A\"},\"userContentCountWithMedia\":13},\"isSemantic\":false,\"definition\":{\"id\":372,\"name\":\"Bluetooth Kulaklıklar\"},\"mainCategory\":{\"id\":16218,\"name\":\"Bluetooth Kulaklıklar\"},\"cardSize\":\"M\",\"CardSizePx\":124,\"al_p\":\"SD87pwP646eeRMpHDm7ZQtTTh97umIwISyaGE/3iz9ktFCTSf6vO8h0FSuYLxXZi/hocNy/OJec3fstW56R+RYb2bWwC437mCvomoagn4S4ktfjLeAP9cXsR7JeAGWXsve1TblbV2XLHBEEydedgwA==\",\"isSplitted\":false,\"isMirosProduct\":0,\"reasonDetails\":\"\",\"isExistColorVariant\":true,\"colorVariantCount