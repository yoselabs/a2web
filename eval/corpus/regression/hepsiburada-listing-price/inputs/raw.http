iceInfo\":{\"price\":1319.44,\"priceTextColor\":\"\",\"originalPrice\":1319.44,\"discountRate\":0,\"discountType\":\"NoDiscount\"},\"isPreOrder\":false,\"inStockDate\":null,\"merchantName\":\"\",\"merchantId\":\"\",\"listingId\":\"d265b817-bd75-4d8f-b31d-6513f84cd7c3\",\"tagList\":null,\"labels\":null,\"categorizedLabels\":{\"incentiveToBuy\":null,\"valueAddedService\":null,\"campaign\":null,\"winner\":null,\"affordability\":null,\"imageLabel\":null,\"hepsiMoney\":null},\"jetDeliveryCities\":null,\"jetDelivery\":false,\"expressDeliveryWarehouses\":null,\"expressDelivery\":false,\"cityBasedCutOffEnabled\":false,\"campaignText\":\"\",\"campaigns\":null,\"minimumPrices\":null,\"shippingProfileId\":\"\",\"shipmentDay\":0,\"aiBasedShipmentDay\":0,\"warehouseId\":\"\",\"availableWarehouses\":null,\"campaignPriceInfo\":null,\"nextEligibleCampaign\":null},\"images\":[{\"link\":\"https://productimages.hepsiburada.net/s/404/{size}/110000429711425.jpg\",\"isDefault\":true,\"height\":1204,\"width\":1064}],\"properties\":{\"Renk\":{\"displayValue\":\"Beyaz\",\"value\":\"Beyaz\"}},\"energyClassInfo\":null,\"winnerFreight\":0,\"trackingInfo\":null,\"taxVatRate\":0,\"adsCampaignOwnerType\":\"\",\"isPromoted\":false,\"adsUniqueId\":\"\",\"merchantId\":\"\",\"adsCampaignId\":\"\",\"adsSupplierId\":\"\"}],\"displayOptions\":{\"isAdultProduct\":false,\"hasColorVariant\":true},\"hasVariant\":true,\"userContentInfo\":{\"bestReview\":{\"content\":\"Uzun araştırma ve incelemeler sonucu karar kılıp olumlu / olumsuz yorumları da göz ardı etmeyerek bu kulaklığı tercih ettim. yaklaşık 6 saat kullandım ve almayı düşünüp kararsız kalanlar için bilgilendirme niteliğinde kulaklıktan bahsedeceğim.\\n\\n-kulaklığın kutusu bir tık dandik havası veriyor ilk başta fakat yine de öyle çıt diye kırılabilecek bir kutu değil, hor kullanmazsanız çizik bile bırakmaz. olumsuz yorumlarda bu konuda çizilme, yıpranma ve kolay tahrip gibi şeyler olduğunu belirtenler var, haklılık payları olsa da bu durum herkesin başına gelmez; dediğim gibi tamamen nasıl kullandığınıza bağlı. lastik ipinin olması küçük ama kesinlikle çok. bu yönden herhangi bir sorun yok.\\n-kulaklıkların dış görünüşü gayet zarif ve dayanıklı görünüyor. tutuş hissi ve kulağı uzun kullanımda rahatsız etmeyen bir dizaynı olması çok iyi. yine olumsuz yorumlardan ilerleyecek olursam tıkaç silikonların kulakta kaldığı, kulaklıktan çıktığı ve tam oturamadığı gibi yorumlar okumuştum, böyle bir şey kullandığım süreçte pek mümkün gelmedi bana. zaten kutu içerisinde de kulağınıza uygun olacak şekilde iki ayrı boyutta silikon tıkaçlar mevcut.\\n-ses konusuna gelecek olursak tek kelimeyle harika diyeceğim. samsung galaxy buds ve airpods pro gibi katlarca daha pahalı kulaklıklarla karşılaştırma cüretinde bulundum ve inanın bana bu fiyat aralığında böyle kaliteli tiz ve kuvvetli bass'ı olan bir kulaklık daha bulamazsınız. ANC yok fakat kulağa taktığınızda dışarıdaki sesi tamamen kesiyor.\\n-yine Soundcore uygulamasına yönelik olumsuz yorumlar var, aldanmayın. sese yönelik çeşit çeşit seçenekler sunuyor. ayrıca saatlerce deneyimlediğim kullanım sürecinde tek bir kopma dahi yaşamadım.\\n-son olarak şarj süresi beni tatmin etti. mikrofon kalitesi hariç neredeyse hiçbir olumsuz tarafı yok. birkaç kişiyle oda sessizliğinde, hafif gürültüde ve yüksek gürültüde konuşmalar gerçekleştirdim. çok gürültülü ortamlarda telefonla konuşmak sizi zorlar fakat genel olarak kalite namına olumlu dönüşler aldım.\",\"firstname\":\"E\",\"lastname\":\"D\"},\"userContentCountWithMedia\":855},\"isSemantic\":false,\"definition\":{\"id\":372,\"name\":\"Bluetooth Kulaklıklar\"},\"mainCategory\":{\"id\":16218,\"name\":\"Bluetooth Kulaklıklar\"},\"cardSize\":\"M\",\"CardSizePx\":124,\"al_p\":\"kV7bxkVJU9rLaOJQtPDrpyNyEkrgf1UYJ14Fn1qAZcfce/1hWW/xuxZj7W/75kc59Q/TL+/lMX84CCPOumuHdAMzArMBjxYtEuIlIyKJ1e/hsDOs3FsNZ78XgE72onM5QbaSmPTbDXiKxLc5pm1NUkW9hr1Xi0GHyL+CQt9ntjY=\",\"isSplitted\":false,\"isMirosProduct\":0,\"reasonDetails\":\"\",\"isExistColorVariant\"