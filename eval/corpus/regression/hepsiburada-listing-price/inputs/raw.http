jpg\",\"isDefault\":true,\"height\":389,\"width\":314}],\"properties\":{\"Renk\":{\"displayValue\":\"Beyaz\",\"value\":\"Beyaz\"}},\"energyClassInfo\":null,\"winnerFreight\":0,\"trackingInfo\":null,\"taxVatRate\":0,\"adsCampaignOwnerType\":\"\",\"isPromoted\":false,\"adsUniqueId\":\"\",\"merchantId\":\"\",\"adsCampaignId\":\"\",\"adsSupplierId\":\"\"}],\"displayOptions\":{\"isAdultProduct\":false,\"hasColorVariant\":true},\"hasVariant\":true,\"userContentInfo\":{\"bestReview\":{\"content\":\"Harika ses kalitesi ve genel olarak mükemmel bir performans, üstelik bu kadar uygun fiyata! Gerçekten çok şaşırdım. Daha çok spor salonu ve antrenmanlar için almıştım, çünkü asıl kullandığım birinci nesil AirPods’ların pili yıllar içinde artık azalmaya başladı. Ama size gönül rahatlığıyla söyleyebilirim ki, bu kulaklıklar müzik dinlemek, podcast’ler için ve spor yapmak adına fazlasıyla yeterli ve harika.\\n\\nKulakta çok rahat oturuyor, adeta hiç hissetmiyorum bile. Seçimimi bunlardan yana yaptım çünkü küçük ve kompakt bir model istiyordum. Xiaomi mağazalarında tükenmişti, bu yüzden siparişimi Hepsiburada üzerinden verdim ve her zamanki gibi teslimat inanılmaz hızlıydı — akşam sipariş verdim, sabah elime ulaştı.\\n\\nBöylesine hızlı ve kaliteli hizmet için çok teşekkür ederim, her zamanki gibi harikasınız!\\nGünlük kullanım için bu kadar uygun fiyata gerçekten mükemmel kulaklıklar!\",\"firstname\":\"K\",\"lastname\":\"D\"},\"userContentCountWithMedia\":363},\"isSemantic\":false,\"definition\":{\"id\":372,\"name\":\"Bluetooth Kulaklıklar\"},\"mainCategory\":{\"id\":16218,\"name\":\"Bluetooth Kulaklıklar\"},\"cardSize\":\"L\",\"CardSizePx\":144,\"al_p\":\"RCT8Gq5JqMJMt/F+xsJDxUyG1pE2EmRhpnFCJN6UL9kBcfw98c0PXmHTpFqYRfULpEFkc16KwRielH6/FESiwb9x9o3AScvR60dJRqRrkFoqeNWxRYGpm8iyi33h3ad9p8dkQ2YjaiWIG4x9WmuVgXL0vznbfM5NJYp0lP9jD1M=\",\"isSplitted\":false,\"isMirosProduct\":0,\"reasonDetails\":\"\",\"isExistColorVariant\":true,\"colorVariantCount\":4,\"installmentLimit\":9},{\"productId\"