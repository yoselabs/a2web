\":false,\"inStockDate\":null,\"merchantName\":\"\",\"merchantId\":\"\",\"listingId\":\"be77aa80-63fd-49d6-950b-067a4a06a070\",\"tagList\":null,\"labels\":null,\"categorizedLabels\":{\"incentiveToBuy\":null,\"valueAddedService\":null,\"campaign\":null,\"winner\":null,\"affordability\":null,\"imageLabel\":null,\"hepsiMoney\":null},\"jetDeliveryCities\":null,\"jetDelivery\":false,\"expressDeliveryWarehouses\":null,\"expressDelivery\":false,\"cityBasedCutOffEnabled\":false,\"campaignText\":\"\",\"campaigns\":null,\"minimumPrices\":null,\"shippingProfileId\":\"\",\"shipmentDay\":0,\"aiBasedShipmentDay\":0,\"warehouseId\":\"\",\"availableWarehouses\":null,\"campaignPriceInfo\":null,\"nextEligibleCampaign\":null},\"images\":[{\"link\":\"https://productimages.hepsiburada.net/s/777/{size}/110001058314455.jpg\",\"isDefault\":true,\"height\":563,\"width\":562}],\"properties\":{\"Renk\":{\"displayValue\":\"Mavi\",\"value\":\"Mavi\"}},\"energyClassInfo\":null,\"winnerFreight\":0,\"trackingInfo\":null,\"taxVatRate\":0,\"adsCampaignOwnerType\":\"\",\"isPromoted\":false,\"adsUniqueId\":\"\",\"merchantId\":\"\",\"adsCampaignId\":\"\",\"adsSupplierId\":\"\"}],\"displayOptions\":{\"isAdultProduct\":false,\"hasColorVariant\":true},\"hasVariant\":true,\"userContentInfo\":{\"bestReview\":{\"content\":\"Kulak algılama şarkıyı rastgele durdurabiliyor, devre dışı bırakın derim. Yedek silikonlar karton kutuda, dikkatli bakın. Audeze Maxwell kulaklığım için The Odyofil YouTube kanalında önerilen EQ ayarına benzer ses karakteristiği için ( karanlık hissiyatlı, yumuşak baslı, midleri boğmayan ve tiz aşırı çınlatmadan yormayan) yapmanız gereken:\\nKulaklık bağlı iken hem telefondan hem de kulaklığın yazılımından Ldac'ı açın. Uzamsal ses kapalı. Ultra bass kapalı. Düşük gecikme modu kapalı.\\nSonra Kişisel Ses Profili'ni yapın ve açık kalsın.\\nEkolayzer Özel seçip bass: +3, orta: -4, tiz: -6 yapın.\\nGürültü İptali Modunu istediğşniz gibi seçin. Ses hem doyurucu hem de başınızı ağrıtmayan bir yapıya dönüyor.\\nMalzeme kalitesi kaliteli hissiyatlı, plastiği mat ve tok hissettiriyor.\",\"firstname\":\"M\",\"lastname\":\"Y\"},\"userContentCountWithMedia\":17},\"isSemantic\":false,\"definition\":{\"id\":372,\"name\":\"Bluetooth Kulaklıklar\"},\"mainCategory\":{\"id\":16218,\"name\":\"Bluetooth Kulaklıklar\"},\"cardSize\":\"L\",\"CardSizePx\":124,\"al_p\":\"F/QWIqVNwIM9tHc3YO66115gQOXUC5+hDKHD0FHBza8y72PLcSapV1PGVqCjhWcLzY1sIBKMnpAGDQdy+AXZNJMAX0BW6GQwEpZ/qvSajkrWMuDldQ8vdBgd6NiIJpVjmP1RSt1Yjko4LanI1MZIq/wdPE0O7ASIhizZn4C1CS0=\",\"isSplitted\":false,\"isMirosProduct\":0,\"reasonDetails\":\"\",\"isExistColorVariant\":true,\"colorVariantCount\":2,\"installmentLimit\":9},{\"productId\":\"HBC00008ZZMKG\",\"brand\":\"Nothing\",\"customerReviewCount\":197,\"customerReviewScore\":5,\"customerReviewRating\":4.5,\"boostingFactors\":[],\"variantList\":[{\"sku\":\"HBCV00008ZZMKH\",\"name\":\"Nothing Cmf Buds 2 Plus - Mavi\",\"url\":\"/nothing-cmf-buds-2-plus-mavi-p-HBCV00008ZZMKH\",\"isDefault\":true,\"procurable\":true,\"adInfo\":\"\",\"adShowId\":\"\",\"isMultiSeller\":false,\"listing\":{\"priceInfo\":{\"price\":1980.31,\"priceTextColor\":\"\",\"originalPrice\":1980.31,\"discountRate\":0,\"discountType\":\"NoDiscount\"},\"isPreOrder\":false,\"inStockDate\":null,\"merchantName\":\"Hepsiburada\",\"merchantId\":\"e750130c-d0ff-469f-8767-66a63af8ea0c\",\"listingId\":\"be77aa80-63fd-49d6-950b-067a4a06a070\",\"tagList\":[{\"tagId\":\"bt-yt-urunleri\",\"tagName\":\"BT/YT Ürünleri\",\"tagGroupName\":\"\",\"startDate\":\"2022-08-01T11:52:20Z\",\"endDate\":\"2029-07-01T20:59:00Z\"}],\"labels\":null,\"categorizedLabels\":{\"incentiveToBuy\":null,\"valueAddedService\":null,\"campaign\":null,\"winner\":null,\"affordability\":[{\"text\":\"Peşin fiyatına 3 x 660 TL\",\"color\":\"#FAF7FD\",\"textColor\":\"#7723DB\",\"tagName\":\"kredi-karti-3-taksit-2-tag\",\"order\":5,\"type\":\"affordability\",\"typeGroup\":\"\",\"tagGroup\":\"\",\"paymentType\":3,\"installmentCount\":3,\"installmen