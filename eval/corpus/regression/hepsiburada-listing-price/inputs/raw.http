ssInfo\":null,\"winnerFreight\":0,\"trackingInfo\":null,\"taxVatRate\":0,\"adsCampaignOwnerType\":\"\",\"isPromoted\":false,\"adsUniqueId\":\"\",\"merchantId\":\"\",\"adsCampaignId\":\"\",\"adsSupplierId\":\"\"},{\"sku\":\"HBCV000049D11K\",\"name\":\"Anker Soundcore R50i TWS Bluetooth Kablosuz Kulaklık Beyaz - IOS ve Android Uyumlu - A3949 (Anker Türkiye Garantili)\",\"url\":\"/anker-soundcore-r50i-tws-bluetooth-kablosuz-kulaklik-beyaz-ios-ve-android-uyumlu-a3949-anker-turkiye-garantili-p-HBCV000049D11K\",\"isDefault\":false,\"procurable\":true,\"adInfo\":\"\",\"adShowId\":\"\",\"isMultiSeller\":false,\"listing\":{\"priceInfo\":{\"price\":1319.44,\"priceTextColor\":\"\",\"originalPrice\":1319.44,\"discountRate\":0,\"discountType\":\"NoDiscount\"},\"isPreOrder\":false,\"inStockDate\":null,\"merchantName\":\"\",\"merchantId\":\"\",\"listingId\":\"d265b817-bd75-4d8f-b31d-6513f84cd7c3\",\"tagList\":null,\"labels\":null,\"categorizedLabels\":{\"incentiveToBuy\":null,\"valueAddedService\":null,\"campaign\":null,\"winner\":null,\"affordability\":null,\"imageLabel\":null,\"hepsiMoney\":null},\"jetDeliveryCities\":null,\"jetDelivery\":false,\"expressDeliveryWarehouses\":null,\"expressDelivery\":false,\"cityBasedCutOffEnabled\":false,\"campaignText\":\"\",\"campaigns\":null,\"minimumPrices\":null,\"shippingProfileId\":\"\",\"shipmentDay\":0,\"aiBasedShipmentDay\":0,\"warehouseId\":\"\",\"availableWarehouses\":null,\"campaignPriceInfo\":null,\"nextEligibleCampaign\":null},\"images\":[{\"link\":\"https://productimages.hepsiburada.net/s/404/{size}/110000429711425.jpg\",\"isDefault\":true,\"height\":1204,\"width\":1064}],\"properties\":{\"Renk\":{\"displayValue\":\"Beyaz\",\"value\":\"Beyaz\"}},\"energyClassInfo\":null,\"winnerFreight\":0,\"trackingInfo\":null,\"taxVatRate\":0,\"adsCampaignOwnerType\":\"\",\"isPromoted\":false,\"adsUniqueId\":\"\",\"merchantId\":\"\",\"adsCampaignId\":\"\",\"adsSupplierId\":\"\"}],\"displayOptions\":{\"isAdultProduct\":false,\"hasColorVariant\":true},\"hasVariant\":true,\"userContentInfo\":{\"bestReview\":{\"content\":\"Uzun araştırma ve incelemeler sonucu karar kılıp olumlu / olumsuz yorumları da göz ardı etmeyerek bu kulaklığı tercih ettim. yaklaşık 6 saat kullandım ve almayı düşünüp kararsız kalanlar için bilgilendirme niteliğinde kulaklıktan bahsedeceğim.\\n\\n-kulaklığın kutusu bir tık dandik havası veriyor ilk başta fakat yine de öyle çıt diye kırılabilecek bir kutu değil, hor kullanmazsanız çizik bile bırakmaz. olumsuz yorumlarda bu konuda çizilme, yıpranma ve kolay tahrip gibi şeyler olduğunu belirtenler var, haklılık payları olsa da bu durum herkesin başına gelmez; dediğim gibi tamamen nasıl kullandığınıza bağlı. lastik ipinin olması küçük ama kesinlikle çok. bu yönden herhangi bir sorun yok.\\n-kulaklıkların dış görünüşü gayet zarif ve dayanıklı görünüyor. tutuş hissi ve kulağı uzun kullanımda rahatsız etmeyen bir dizaynı olması çok iyi. yine olumsuz yorumlardan ilerleyecek olursam tıkaç silikonların kulakta kaldığı, kulaklıktan çıktığı ve tam oturamadığı gibi yorumlar okumuştum, böyle bir şey kullandığım süreçte pek mümkün gelmedi bana. zaten kutu içerisinde de kulağınıza uygun olacak şekilde iki ayrı boyutta silikon tıkaçlar mevcut.\\n-ses konusuna gelecek olursak tek kelimeyle harika diyeceğim. samsung galaxy buds ve airpods pro gibi katlarca daha pahalı kulaklıklarla karşılaştırma cüretinde bulundum ve inanın bana bu fiyat aralığında böyle kaliteli tiz ve kuvvetli bass'ı olan bir kulaklık daha bulamazsınız. ANC yok fakat kulağa taktığınızda dışarıdaki sesi tamamen kesiyor.\\n-yine Soundcore uygulamasına yönelik olumsuz yorumlar var, aldanmayın. sese yönelik çeşit çeşit seçenekler sunuyor. ayrıca saatlerce deneyimlediğim kullanım sürecinde tek bir kopma dahi yaşamadım.\\n-son olarak şarj süresi beni tatmin etti. mikrofon kalitesi hariç neredeyse hiçbir olumsuz tarafı yok. birkaç kişiyle oda sessizliğinde, hafif gürültüde ve yüksek gürültüde konuşmalar gerçekleştirdim. çok gürültülü ortamlarda telefonla konuşmak sizi zorlar fakat genel olarak kalite namına olumlu dönüşler aldım.\",\"firstname\":\"E\",\"lastname\":\"D\"},\"userContentCountWithMedia\":855},\"isSemantic\":false,\"definition\":{\"id\":372,\"name\":\"Bluetooth Kulaklıklar\"},\"mainCategory\":{\"id\":16218,\"name\":\"Bluetooth Kulaklıklar\"},\"cardSize\":\"M\",\"CardSizePx\":124,\"al_p\":\"kV7bxkVJU9rLaOJQtPDrpyNyEkrgf1UYJ14Fn1qAZcfce/1hWW/xuxZj7W/75kc59Q/TL+/lMX84CCPOumuHdAMzArMBjxYtEuIlIyKJ1e/hsDOs3FsNZ78XgE72onM5QbaSmPTbDXiKxLc5pm1NUkW9hr1Xi0GHyL+CQt9ntjY=\",\"isSplitted\":false,\"isMirosProduct\":0,\"reasonDetails\":\"\",\"isExistColorVariant\":true,\"colorVariantCount\":4,\"installmentLimit\":9},{\"productId\":\"HBC00004SANT7\",\"brand\":\"Huawei\",\"customerReviewCount\":8123,\"customerReviewScore\":5,\"customerReviewRating\":4.7,\"boostingFactors\":[],\"variantList\":[{\"sku\":\"HBCV00006K5HM4\",\"name\":\"Huawei Freebuds Se 2 - Siyah\",\"url\":\"/huawei-freebuds-se-2-siyah-p-HBCV00006K5HM4\",\"isDefault\":true,\"procurable\":true,\"adInfo\":\"\",\"adShowId\":\"\",\"isMultiSeller\":true,\"listing\":{\"priceInfo\":{\"price\":1293,\"priceTextColor\":\"\",\"originalPrice\":1293,\"discountRate\":0,\"discountType\":\"NoDiscount\"},\"isPreOrder\":false,\"inStockDate\":null,\"merchantName\":\"Hepsiburada\",\"merchantId\":\"e750130c-d0ff-469f-8767-66a63af8ea0c\",\"listingId\":\"7c724b80-0d44-4d69-a1f8-47439da43eec\",\"tagList\":[{\"tagId\":\"bt-yt-urunleri\",\"tagName\":\"BT/YT Ürünleri\",\"tagGroupName\":\"\",\"startDate\":\"2022-08-01T11:52:20Z\",\"endDate\":\"2029-07-01T20:59:00Z\"}],\"labels\":null,\"categorizedLabels\":{\"incentiveToBuy\":null,\"valueAddedService\":null,\"campaign\":null,\"winner\":null,\"affordability\":[{\"text\":\"Peşin fiyatına 3 x 431 TL\",\"color\":\"#FAF7FD\",\"textColor\":\"#7723DB\",\"tagName\":\"kredi-karti-3-taksit\",\"order\":5,\"type\":\"affordability\",\"typeGroup\":\"\",\"tagGroup\":\"\",\"paymentType\":3,\"installmentCount\":3,\"installmentAmount\":431,\"isCa