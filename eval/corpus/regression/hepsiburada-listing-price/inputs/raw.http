scount\"},\"isPreOrder\":false,\"inStockDate\":null,\"merchantName\":\"\",\"merchantId\":\"\",\"listingId\":\"d8c60284-c6dc-40dd-aea0-191012e1ccbe\",\"tagList\":null,\"labels\":null,\"categorizedLabels\":{\"incentiveToBuy\":null,\"valueAddedService\":null,\"campaign\":null,\"winner\":null,\"affordability\":null,\"imageLabel\":null,\"hepsiMoney\":null},\"jetDeliveryCities\":null,\"jetDelivery\":false,\"expressDeliveryWarehouses\":null,\"expressDelivery\":false,\"cityBasedCutOffEnabled\":false,\"campaignText\":\"\",\"campaigns\":null,\"minimumPrices\":null,\"shippingProfileId\":\"\",\"shipmentDay\":0,\"aiBasedShipmentDay\":0,\"warehouseId\":\"\",\"availableWarehouses\":null,\"campaignPriceInfo\":null,\"nextEligibleCampaign\":null},\"images\":[{\"link\":\"https://productimages.hepsiburada.net/s/396/{size}/110000421499525.jpg\",\"isDefault\":true,\"height\":770,\"width\":485}],\"properties\":{\"Renk\":{\"displayValue\":\"Beyaz\",\"value\":\"Beyaz\"}},\"energyClassInfo\":null,\"winnerFreight\":0,\"trackingInfo\":null,\"taxVatRate\":0,\"adsCampaignOwnerType\":\"\",\"isPromoted\":false,\"adsUniqueId\":\"\",\"merchantId\":\"\",\"adsCampaignId\":\"\",\"adsSupplierId\":\"\"}],\"displayOptions\":{\"isAdultProduct\":false,\"hasColorVariant\":true},\"hasVariant\":true,\"userContentInfo\":{\"bestReview\":{\"content\":\"Kargo bir haftada geldi çünkü 4 gün boyunca ürün hazırlandı. Eşimde beyaz var diye ben de siyah sipariş ettim ancak beyaz geldi. Üstelik uygulamasında siyah görünüyor 😂 Haftalar sürüyor o nedenle iadeyle uğraşmayacağım. Daha iyi ses kalitesi olan kulaklık denemedim o nedenle bana göre sesi çok iyi. ANC modu çok sesli ortamda yeterli değil. Şeffaf modu var orta ses seviyesinde iş görüyor yüksek seste etraftaki sesleri duyamıyorum. Uygulamasındaki ekolayzır ayarları güzel. Ara sıra bağlantı kopuyor farkedilmeyebilir. Oyun modu var sadece oyun açıkken gecikme epey azaltılmış ancak yine de yakın savaşlarda üzer. Müzik programı ve oyun aynı anda açıksa gecikme belli edi