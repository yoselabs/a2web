riceTextColor\":\"\",\"originalPrice\":678.78,\"discountRate\":0,\"discountType\":\"NoDiscount\"},\"isPreOrder\":false,\"inStockDate\":null,\"merchantName\":\"\",\"merchantId\":\"\",\"listingId\":\"104b2b80-cb63-4bbb-b223-db64d903e5a3\",\"tagList\":null,\"labels\":null,\"categorizedLabels\":{\"incentiveToBuy\":null,\"valueAddedService\":null,\"campaign\":null,\"winner\":null,\"affordability\":null,\"imageLabel\":null,\"hepsiMoney\":null},\"jetDeliveryCities\":null,\"jetDelivery\":false,\"expressDeliveryWarehouses\":null,\"expressDelivery\":false,\"cityBasedCutOffEnabled\":false,\"campaignText\":\"\",\"campaigns\":null,\"minimumPrices\":null,\"shippingProfileId\":\"\",\"shipmentDay\":0,\"aiBasedShipmentDay\":0,\"warehouseId\":\"\",\"availableWarehouses\":null,\"campaignPriceInfo\":null,\"nextEligibleCampaign\":null},\"images\":[{\"link\":\"https://productimages.hepsiburada.net/s/777/{size}/110000792817673.jpg\",\"isDefault\":true,\"height\":391,\"width\":318}],\"properties\":{\"Renk\":{\"displayValue\":\"Siyah\",\"value\":\"Siyah\"}},\"energyClassInfo\":null,\"winnerFreight\":0,\"trackingInfo\":null,\"taxVatRate\":0,\"adsCampaignOwnerType\":\"\",\"isPromoted\":false,\"adsUniqueId\":\"\",\"merchantId\":\"\",\"adsCampaignId\":\"\",\"adsSupplierId\":\"\"}],\"displayOptions\":{\"isAdultProduct\":false,\"hasColorVariant\":true},\"hasVariant\":true,\"userContentInfo\":{\"bestReview\":{\"content\":\"Harika ses kalitesi ve genel olarak mükemmel bir performans, üstelik bu kadar uygun fiyata! Gerçekten çok şaşırdım. Daha çok spor salonu ve antrenmanlar için almıştım, çünkü asıl kullandığım birinci nesil AirPods’ların pili yıllar içinde artık azalmaya başladı. Ama size gönül rahatlığıyla söyleyebilirim ki, bu kulaklıklar müzik dinlemek, podcast’ler için ve spor yapmak adına fazlasıyla yeterli ve harika.\\n\\nKulakta çok rahat oturuyor, adeta hiç hissetmiyorum bile. Seçimimi bunlardan yana yaptım çünkü küçük ve kompakt bir model istiyordum. Xiaomi mağazalarında tükenmişti, bu yü