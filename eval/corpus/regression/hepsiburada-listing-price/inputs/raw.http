Order\":false,\"inStockDate\":null,\"merchantName\":\"\",\"merchantId\":\"\",\"listingId\":\"104b2b80-cb63-4bbb-b223-db64d903e5a3\",\"tagList\":null,\"labels\":null,\"categorizedLabels\":{\"incentiveToBuy\":null,\"valueAddedService\":null,\"campaign\":null,\"winner\":null,\"affordability\":null,\"imageLabel\":null,\"hepsiMoney\":null},\"jetDeliveryCities\":null,\"jetDelivery\":false,\"expressDeliveryWarehouses\":null,\"expressDelivery\":false,\"cityBasedCutOffEnabled\":false,\"campaignText\":\"\",\"campaigns\":null,\"minimumPrices\":null,\"shippingProfileId\":\"\",\"shipmentDay\":0,\"aiBasedShipmentDay\":0,\"warehouseId\":\"\",\"availableWarehouses\":null,\"campaignPriceInfo\":null,\"nextEligibleCampaign\":null},\"images\":[{\"link\":\"https://productimages.hepsiburada.net/s/777/{size}/110000792817673.jpg\",\"isDefault\":true,\"height\":391,\"width\":318}],\"properties\":{\"Renk\":{\"displayValue\":\"Siyah\",\"value\":\"Siyah\"}},\"energyClassInfo\":null,\"winnerFreight\":0,\"trackingInfo\":null,\"taxVatRate\":0,\"adsCampaignOwnerType\":\"\",\"isPromoted\":false,\"adsUniqueId\":\"\",\"merchantId\":\"\",\"adsCampaignId\":\"\",\"adsSupplierId\":\"\"}],\"displayOptions\":{\"isAdultProduct\":false,\"hasColorVariant\":true},\"hasVariant\":true,\"userContentInfo\":{\"bestReview\":{\"content\":\"Harika ses kalitesi ve genel olarak mükemmel bir performans, üstelik bu kadar uygun fiyata! Gerçekten çok şaşırdım. Daha çok spor salonu ve antrenmanlar için almıştım, çünkü asıl kullandığım birinci nesil AirPods’ların pili yıllar içinde artık azalmaya başladı. Ama size gönül rahatlığıyla söyleyebilirim ki, bu kulaklıklar müzik dinlemek, podcast’ler için ve spor yapmak adına fazlasıyla yeterli ve harika.\\n\\nKulakta çok rahat oturuyor, adeta hiç hissetmiyorum bile. Seçimimi bunlardan yana yaptım çünkü küçük ve kompakt bir model istiyordum. Xiaomi mağazalarında tükenmişti, bu yüzden siparişimi Hepsiburada üzerinden verdim ve her zamanki gibi teslimat inanılmaz hızlıydı — akşam sipariş verdim, sabah elime ulaştı.\\n\\nBöylesine hızlı ve kaliteli hizmet için çok teşekkür ederim, her zamanki gibi harikasınız!\\nGünlük kullanım için bu kadar uygun fiyata gerçekten mükemmel kulaklıklar!\",\"firstname\":\"K\",\"lastname\":\"D\"},\"userContentCountWithMedia\":363},\"isSemantic\":false,\"definition\":{\"id\":372,\"name\":\"Bluetooth Kulaklıklar\"},\"mainCategory\":{\"id\":16218,\"name\":\"Bluetooth Kulaklıklar\"},\"cardSize\":\"M\",\"CardSizePx\":124,\"al_p\":\"ABMYjMFvkAS6RSc04Vxf2/6ba3whJUdTp0mc4/jFuag4jn5pFrjE3rwOzNNxcltnm/lPP1G0rvVyT6fvdqyY3MkpnvVFwhbarAuCovPH6k7aPgUvd5E8wjYGneAOfJmZCdkDAxvGDZP/w6ZXvKgOy1yhTDoHzV9rz7Z54nZ7wl8=\",\"isSplitted\":false,\"isMirosProduct\":0,\"reasonDetails\":\"\",\"isExistColorVariant\":true,\"colorVariantCount\":4,\"installmentLimit\":9},{\"productId\":\"HBC00007BZNDY\",\"brand\":\"Xiaomi\",\"customerReviewCount\":7131,\"customerReviewScore\":4,\"customerReviewRating\":4.4,\"boostingFactors\":[\"en-avantajli-fiyatlar\"],\"variantList\":[{\"sku\":\"HBCV00007BZNDZ\",\"name\":\"Redmi Buds 6 Play Mavi Bluetooth Kulaklık - Suya ve Tere Dayanıklı, Aktif Gürültü Önleme Özellikli\",\"url\":\"/redmi-buds-6-play-mavi-bluetooth-kulaklik-suya-ve-tere-dayanikli-aktif-gurultu-onleme-ozellikli-p-HBCV00007BZNDZ\",\"isDefault\":true,\"procurable\":true,\"adInfo\":\"\",\"adShowId\":\"\",\"isMultiSeller\":true,\"listing\":{\"priceInfo\":{\"price\":679.21,\"priceTextColor\":\"\",\"originalPrice\":679.21,\"discountRate\":0,\"discountType\":\"NoDiscount\"},\"isPreOrder\":false,\"inStockDate\":null,\"merchantName\":\"Hepsiburada\",\"merchantId\":\"e750130c-d0ff-469f-8767-66a63af8ea0c\",\"listingId\":\"a02aca2b-fd1c-45b9-a3a5-ae0ea853a91e\",\"tagList\":[{\"tagId\":\"bt-yt-urunleri\",\"tagName\":\"BT/YT Ürünleri\",\"tagGroupName\":\"\",\"startDate\":\"2022-08-01T11:52:20Z\",\"endDate\":\"2029-07-01T20:59:00Z\"}],\"labels\":null,\"categorizedLabels\":{\"incentiveToBuy\":null,\"valueAddedService\":null,\"campaign\":null,\"winner\":null,\"affo