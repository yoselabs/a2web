        <script>
          try {
            const efilliBannerObserver = new MutationObserver(() => {
              const efilliElement = document.querySelector('efilli-layout-dynamic')
              if (!efilliElement) return

              const hasSavedConsent = window.efilliSdk.consentManager.getSavedConsent()

              if (!hasSavedConsent) {
                const shadowRoot = efilliElement.shadowRoot
                const style = document.createElement('style')

                style.textContent = '@media (min-width:768px){#hb-accept-all,#hb-open-settings{width:150px!important}}#hb-accept-all,#hb-open-settings{width:100%;padding-inline:12px;height:32px;line-height:32px;border-radius:6px;font-weight:700;cursor:pointer;text-align:center}#hb-accept-all{color:#fff;background-color:#ff6000}#hb-open-settings{color:#ff6000;background-color:transparent;text-decoration:underline}#hb-reject-all{text-decoration:underline;font-weight:700;color:#ff6000;font-size:13px;cursor:pointer}'
                shadowRoot.appendChild(style)

                const efilliAcceptButton = shadowRoot.querySelector('[data-name="Accept Button"]')
                const efilliRejectAllButton = shadowRoot.querySelector('[data-name="reject button"]')
                const efilliOpenSettingsButton = shadowRoot.querySelector('[data-name="Settings Button"]')
                const efilliPopup = shadowRoot.querySelector('[data-name="Popup Container"]')
                const efilliPopupContent = shadowRoot.querySelector('[data-name="Content"]')

                if (efilliPopupContent) {
                  efilliPopupContent.classList.remove('animate-zoom-in', 'animate-duration-150');
                }

                const hbAcceptAllButton = Object.assign(document.createElement('div'), {
                  textContent: 'Kabul Et',
                  id: 'hb-accept-all',
                  onclick: () => {
                    efilliElement.style.display = 'none'

                    setTimeout(() => window.efilliSdk.consentManager.acceptAll({ save: true }), 0)
                  }
                })

                const hbOpenSettingsButton = Object.assign(document.createElement('div'), {
                  textContent: 'Çerez Ayarları',
                  id: 'hb-open-settings',
                  onclick: () => {
                    efilliPopup.removeAttribute('hidden')
                  }
                })

                const hbRejectAllButton = Object.assign(document.createElement('span'), {
                  textContent: 'Reddet',
                  id: 'hb-reject-all',
                  onclick: () => {
                    efilliElement.style.display = 'none'

                    setTimeout(() => window.efilliSdk.consentManager.rejectAll(), 0)
                  }
                })

                efilliAcceptButton.replaceWith(hbAcceptAllButton)
                efilliOpenSettingsButton.replaceWith(hbOpenSettingsButton)
                efilliRejectAllButton.replaceWith(hbRejectAllButton)
              }

              efilliBannerObserver.disconnect()
            })

            efilliBannerObserver.observe(document.body, { childList: true })
          } catch (error) {
            console.log('Error From Custom Efilli Consent')
          }
        </script>  
        
      <script type="text/javascript"  src="/RohQ82ajf2XSxLrgkDBR/pOiVwVh0utw0NzEOat/SAsPOw/YSAvPR5/jBgcC"></script></body>
