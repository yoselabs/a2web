iceInfo\":{\"price\":849,\"priceTextColor\":\"\",\"originalPrice\":849,\"discountRate\":0,\"discountType\":\"NoDiscount\"},\"isPreOrder\":false,\"inStockDate\":null,\"merchantName\":\"\",\"merchantId\":\"\",\"listingId\":\"1d033355-55a9-4fa3-9f51-51dff3e1428f\",\"tagList\":null,\"labels\":null,\"categorizedLabels\":{\"incentiveToBuy\":null,\"valueAddedService\":null,\"campaign\":null,\"winner\":null,\"affordability\":null,\"imageLabel\":null,\"hepsiMoney\":null},\"jetDeliveryCities\":null,\"jetDelivery\":false,\"expressDeliveryWarehouses\":null,\"expressDelivery\":false,\"cityBasedCutOffEnabled\":false,\"campaignText\":\"\",\"campaigns\":null,\"minimumPrices\":null,\"shippingProfileId\":\"\",\"shipmentDay\":0,\"aiBasedShipmentDay\":0,\"warehouseId\":\"\",\"availableWarehouses\":null,\"campaignPriceInfo\":null,\"nextEligibleCampaign\":null},\"images\":[{\"link\":\"https://productimages.hepsiburada.net/s/396/{size}/110000421499589.jpg\",\"isDefault\":true,\"height\":562,\"width\":688}],\"properties\":{\"Renk\":{\"displayValue\":\"Siyah\",\"value\":\"Siyah\"}},\"energyClassInfo\":null,\"winnerFreight\":0,\"trackingInfo\":null,\"taxVatRate\":0,\"adsCampaignOwnerType\":\"\",\"isPromoted\":false,\"adsUniqueId\":\"\",\"merchantId\":\"\",\"adsCampaignId\":\"\",\"adsSupplierId\":\"\"}],\"displayOptions\":{\"isAdultProduct\":false,\"hasColorVariant\":true},\"hasVariant\":true,\"userContentInfo\":{\"bestReview\":{\"content\":\"Kargo bir haftada geldi çünkü 4 gün boyunca ürün hazırlandı. Eşimde beyaz var diye ben de siyah sipariş ettim ancak beyaz geldi. Üstelik uygulamasında siyah görünüyor 😂 Haftalar sürüyor o nedenle iadeyle uğraşmayacağım. Daha iyi ses kalitesi olan kulaklık denemedim o nedenle bana göre sesi çok iyi. ANC modu çok sesli ortamda yeterli değil. Şeffaf modu var orta ses seviyesinde iş görüyor yüksek seste etraftaki sesleri duyamıyorum. Uygulamasındaki ekolayzır ayarları güzel. Ara sıra bağlantı kopuyor farkedilmeyebilir. Oyun modu var sadece oyun açıkken gecik