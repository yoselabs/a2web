<script id="allrecipes-schema_1-0" class="comp allrecipes-schema mntl-schema-unified" type="application/ld+json">[
{
"@context": "http://schema.org",
"@type": ["Recipe","NewsArticle"]
,"headline": "Banana Banana Bread"
,"datePublished": "2000-07-11T13:40:38-04:00"
,"dateModified": "2026-02-13T07:10:16-05:00"
,"author": [
{"@type": "Person"
,"name": "Shelley Albeluhn"
}
]
,"description": "This banana bread recipe makes an incredibly moist, delicious loaf with very ripe bananas for loads of banana flavor. It tastes even better toasted!"
,"image": {
"@type": "ImageObject",
"url": "https://www.allrecipes.com/thmb/fAkQn-FhjF89oTJ5JXpgwvwNf34=/1500x0/filters:no_upscale():max_bytes(150000):strip_icc()/20144-banana-banana-bread-VAT-009-4x3-B-78f1cfc64bfa451e8a0fead814719b9f.jpg",
"height": 1125,
"width": 1500
}
,"video": {
"@type": "VideoObject",
"contentUrl": "https://cdn.jwplayer.com/videos/sKQCCYGD-K3AjnAEN.mp4",
"description": "This banana bread recipe is AllRecipes's most popular recipe ever! In this video, Nicole makes a moist and delicious banana banana bread. After mixing the flour, salt, and sugar, combine the mixture with mashed bananas, brown sugar, butter, and two eggs. Transfer the mixture to a loaf pan and bake it in the oven for around an hour. The banana flavor is so sweet and intense that you have to put banana in the name twice!",
"duration": "PT2M18S",
"name": "How to Make Banana Banana Bread",
"thumbnailUrl": "https://cdn.jwplayer.com/v2/media/sKQCCYGD/thumbnails/AOH9lScy.jpg?width=1280",
"uploadDate": "2023-04-21T14:48:16-04:00"}
,"publisher": {
"@type": "Organization",
"name": "Allrecipes",
"url": "https://www.allrecipes.com",
"logo": {
