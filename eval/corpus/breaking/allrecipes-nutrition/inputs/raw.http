"ratingValue": "5"
},
"author": {
"@type": "Person",
"name": "Lupe"
},
"reviewBody": "I've made many different variations of banana bread and this recipe is by far the BEST. Never change it! It will be on rotation in my kitchen!",
"datePublished": "2026-06-09T02:27:29.756Z"
}
,
{
