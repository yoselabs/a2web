"@type": "Person",
"name": "Sally Barrick Sheridan"
},
"reviewBody": "I split the sugar allowance and used both white and brown sugars. Also added a good splash of vanilla and a dash of cinnamon.",
"datePublished": "2026-06-08T21:12:03.630Z"
}
,
