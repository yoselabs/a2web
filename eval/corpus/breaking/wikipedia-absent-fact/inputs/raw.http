                <mo>,</mo>
                <mi>V</mi>
                <mo stretchy="false">)</mo>
                <mo>=</mo>
                <mrow class="MJX-TeXAtom-ORD">
                  <mtext>softmax</mtext>
                </mrow>
                <mrow>
                  <mo>(</mo>
                  <mrow>
                    <mrow class="MJX-TeXAtom-ORD">
                      <mfrac>
                        <mrow>
                          <mi>Q</mi>
                          <msup>
                            <mi>K</mi>
