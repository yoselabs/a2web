                  <mrow class="MJX-TeXAtom-ORD">
                    <mn mathvariant="bold">0</mn>
                  </mrow>
                </mtd>
                <mtd>
                  <msub>
                    <mi>M</mi>
                    <mrow class="MJX-TeXAtom-ORD">
                      <mtext>causal</mtext>
                    </mrow>
                  </msub>
