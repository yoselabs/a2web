    <annotation encoding="application/x-tex">{\displaystyle {\begin{aligned}{\text{given input vectors }}&amp;h_{0},h_{1},\dots \\{\text{combine them into a matrix }}H&amp;={\begin{bmatrix}h_{0}\\h_{1}\\\vdots \end{bmatrix}}\\{\text{EncoderLayer}}(H)&amp;={\begin{bmatrix}{\text{FFN}}({\text{MultiheadAttention}}(H,H,H)_{0})\\{\text{FFN}}({\text{MultiheadAttention}}(H,H,H)_{1})\\\vdots \end{bmatrix}}\\\end{aligned}}}</annotation>
