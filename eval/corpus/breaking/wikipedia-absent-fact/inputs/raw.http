                          <mi>d</mi>
                          <mrow class="MJX-TeXAtom-ORD">
                            <mi>k</mi>
                          </mrow>
                        </msub>
                      </msqrt>
                    </mfrac>
                  </mrow>
                  <mo>)</mo>
